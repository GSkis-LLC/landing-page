              </div>

              <div class="pw-spacer"></div>

              <!-- Promotion marquee -->
              <div class="pw-marquee-wrap hidden" id="pw-marquee-wrap">
                <span class="pw-marquee" id="pw-marquee-text"></span>
              </div>

              <div class="pw-trusted">Trusted by thousands in recovery</div>

              <!-- Subscription options -->
              <div id="pw-options"></div>

              <!-- CTA -->
              <div class="pw-cta-btn" id="pw-cta-btn">Try for $0.00</div>
              <div class="pw-cta-sub" id="pw-cta-sub"></div>

              <!-- Footer -->
              <div class="pw-footer">
                <a href="#">Terms of Use</a>
                <a href="#">Restore</a>
                <a href="#">Privacy Policy</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      </div>

      <div class="tab-panel" id="tab-aso">
        <div class="aso-panel">
          <div class="aso-layout">
            <div class="aso-controls">
              <h3>ASO Rank Checker</h3>

              <div class="aso-field">
                <label for="aso-keywords">Keywords (one per line)</label>
                <textarea id="aso-keywords" spellcheck="false">aa
alcoholics anonymous
aa meetings
aa meeting finder
aa meeting guide
everything aa
my meetings aa
al-anon meetings</textarea>
              </div>

              <div class="aso-inline">
                <div class="aso-field">
                  <label for="aso-app-id">App Store App ID</label>
                  <input id="aso-app-id" type="text" value="6748364894" />
                </div>
                <div class="aso-field">
                  <label for="aso-country">Country</label>
                  <input id="aso-country" type="text" value="us" maxlength="2" />
                </div>
              </div>

              <button class="aso-run-btn" id="aso-run-btn" type="button">Run Check</button>
              <p class="aso-status" id="aso-status"></p>
            </div>

            <div class="aso-results-wrap">
              <h3>Results</h3>
              <div class="aso-results" id="aso-results"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-panel" id="tab-notifications">
        <div class="notifications-panel">
          <div class="notifications-layout">
            <div class="notif-card">
              <h3>Compose Notification</h3>

              <div class="notif-field">
                <label for="notif-template">Template</label>
                <select id="notif-template">
                  <option value="offer_v3">40% Off Premium Offer</option>
                  <option value="blank">Blank</option>
                </select>
              </div>

              <div class="notif-field">
                <label for="notif-title">Title</label>
                <div class="notif-row">
                  <input id="notif-title" type="text" />
                  <button id="notif-title-default" type="button" class="notif-default-btn">Default</button>
                </div>
              </div>

              <div class="notif-field">
                <label for="notif-message">Message</label>
                <div class="notif-row">
                  <textarea id="notif-message"></textarea>
                  <button id="notif-message-default" type="button" class="notif-default-btn">Default</button>
                </div>
              </div>

              <div class="notif-field">
                <label for="notif-deeplink">Deep Link</label>
                <div class="notif-row">
                  <input id="notif-deeplink" type="text" />
                  <button id="notif-deeplink-default" type="button" class="notif-default-btn">Default</button>
                </div>
              </div>

              <button class="notif-send-btn" id="notif-send-btn" type="button">Send Notification</button>
              <p class="notif-status" id="notif-send-status"></p>
            </div>

            <div class="notif-card">
              <h3>Find User</h3>

              <div class="notif-field">
                <label for="notif-user-query">Search by username or email</label>
                <div class="notif-row">
                  <input id="notif-user-query" type="text" placeholder="e.g. jane@example.com" />
                  <button class="notif-search-btn" id="notif-search-btn" type="button">Search</button>
                </div>
              </div>

              <div class="notif-selected-user" id="notif-selected-user">No user selected</div>
              <p class="notif-status" id="notif-search-status"></p>
              <div class="notif-results" id="notif-results"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-panel" id="tab-groups">
        <div class="groups-layout">
          <div class="groups-sidebar">
            <div class="groups-sidebar-header">
              <h3>Organizations</h3>
              <input type="text" class="org-search" id="org-search" placeholder="Search by name or code…" />
            </div>
            <div class="groups-sidebar-list" id="groups-list"></div>
          </div>
          <div class="groups-detail" id="groups-detail">
            <div class="groups-empty">Select an organization to view details</div>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      const API = 'https://api.gskis.com';

      // Price map per promotionVersion
      const PRICES = {
        1: { monthly: 4.99, annual: 39.99 },
        2: { monthly: 7.99, annual: 79.99 },
        3: { monthly: 2.99, annual: 24.99 },
      };

      const FEATURES = [
        { icon: '✨', title: 'AI Insights & Coaching', desc: 'Get personalized AI insights and coaching on your notes' },
        { icon: '💡', title: 'Recommended Meetings', desc: 'Get meeting recommendations based on your location and history' },
        { icon: '📈', title: 'Advanced Analytics', desc: 'Dive deep into your sobriety trends with advanced analytics' },
        { icon: '🗺️', title: 'Meeting Street View', desc: 'Know exactly where your meetings are with interactive street view maps' },
        { icon: '🎨', title: 'Your App, Your Theme', desc: 'Make the app truly yours with a custom color scheme' },
        { icon: '📝', title: 'Unlimited Notes', desc: 'Remove all limits on notes and log all of your thoughts and feelings' },
        { icon: '👥', title: 'Private Groups', desc: 'Create private groups to share your sobriety journey with' },
      ];

      const ASO_DEFAULT_KEYWORDS = [
        'aa meeting finder',
        'aa meeting guide',
        'aa meetings',
        'meeting guide',
        'aa',
        'alcoholics anonymous',
        'everything aa',
        'my meetings aa',
        'al-anon meetings',
      ];

      const NOTIFICATION_DEFAULTS = {
        title: 'Come back and get 40% off premium features',
        message: 'You deserve the best tools to stay sober 🩵',
        deeplink: 'mymeetings://offer/v3',
      };

      // State
      let token = null;
      let currentConfig = {
        promotion: '',
        promotionVersion: 1,
        enableOnboardingRescue: false,
        isOnboardingHardPaywall: false,
        showDailyPrice: false,
        showAmountCTA: true,
      };
      let selectedPlan = 'monthly'; // preview selection

      // DOM refs
      const loginGate = document.getElementById('login-gate');
      const dashboard = document.getElementById('dashboard');
      const loginBtn = document.getElementById('login-btn');
      const loginError = document.getElementById('login-error');
      const loginUser = document.getElementById('login-user');
      const loginPass = document.getElementById('login-pass');
      const logoutBtn = document.getElementById('logout-btn');
      const saveBtn = document.getElementById('save-btn');
      const saveStatus = document.getElementById('save-status');

      // Config inputs
      const cfgPromotion = document.getElementById('cfg-promotion');
      const cfgOnboarding = document.getElementById('cfg-onboarding-rescue');
      const cfgOnboardingHardPaywall = document.getElementById('cfg-onboarding-hard-paywall');
      const cfgShowDaily = document.getElementById('cfg-show-daily');
      const cfgShowAmount = document.getElementById('cfg-show-amount');
      const versionBtns = document.querySelectorAll('.version-btn');

      // Groups state
      let organizations = [];
      let selectedOrg = null;
      let groupsFetched = false;
      let notificationSelectedUser = null;
      let notificationSearchResults = [];

      // Tabs
      const tabButtons = document.querySelectorAll('.tab-btn');
      const tabPaywall = document.getElementById('tab-paywall');
      const tabAso = document.getElementById('tab-aso');
      const tabNotifications = document.getElementById('tab-notifications');
      const tabGroups = document.getElementById('tab-groups');

      // Groups DOM refs
      const orgSearchInput = document.getElementById('org-search');
      const groupsList = document.getElementById('groups-list');
      const groupsDetail = document.getElementById('groups-detail');

      // ASO refs
      const asoKeywords = document.getElementById('aso-keywords');
      const asoAppId = document.getElementById('aso-app-id');
      const asoCountry = document.getElementById('aso-country');
      const asoRunBtn = document.getElementById('aso-run-btn');
      const asoStatus = document.getElementById('aso-status');
      const asoResults = document.getElementById('aso-results');

      // Notification refs
      const notifTemplate = document.getElementById('notif-template');
      const notifTitle = document.getElementById('notif-title');
      const notifMessage = document.getElementById('notif-message');
      const notifDeeplink = document.getElementById('notif-deeplink');
      const notifTitleDefaultBtn = document.getElementById('notif-title-default');
      const notifMessageDefaultBtn = document.getElementById('notif-message-default');
      const notifDeeplinkDefaultBtn = document.getElementById('notif-deeplink-default');
      const notifUserQuery = document.getElementById('notif-user-query');
      const notifSearchBtn = document.getElementById('notif-search-btn');
      const notifSearchStatus = document.getElementById('notif-search-status');
      const notifResults = document.getElementById('notif-results');
      const notifSelectedUser = document.getElementById('notif-selected-user');
      const notifSendBtn = document.getElementById('notif-send-btn');
      const notifSendStatus = document.getElementById('notif-send-status');

      function switchTab(tabName) {
        tabButtons.forEach((btn) => {
          btn.classList.toggle('active', btn.dataset.tab === tabName);
        });
        tabPaywall.classList.toggle('active', tabName === 'paywall');
        tabAso.classList.toggle('active', tabName === 'aso');
        tabNotifications.classList.toggle('active', tabName === 'notifications');
        tabGroups.classList.toggle('active', tabName === 'groups');
        if (tabName === 'groups' && !groupsFetched && token) {
          fetchOrganizations();
        }
      }

      tabButtons.forEach((btn) => {
        btn.addEventListener('click', () => switchTab(btn.dataset.tab));
      });

      // ── Login ──
      async function doLogin() {
        loginError.textContent = '';
        loginBtn.disabled = true;
        loginBtn.textContent = 'Signing in…';
        try {
          const res = await fetch(`${API}/api/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              username: loginUser.value.trim(),
              password: loginPass.value,
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Login failed');
          token = data.token;
          loginGate.style.display = 'none';
          dashboard.style.display = 'flex';
          dashboard.style.flexDirection = 'column';
          await fetchConfig();
        } catch (e) {
          loginError.textContent = e.message;
        } finally {
          loginBtn.disabled = false;
          loginBtn.textContent = 'Sign In';
        }
      }

      loginBtn.addEventListener('click', doLogin);
      loginPass.addEventListener('keydown', (e) => { if (e.key === 'Enter') doLogin(); });
      loginUser.addEventListener('keydown', (e) => { if (e.key === 'Enter') loginPass.focus(); });

      logoutBtn.addEventListener('click', () => {
        token = null;
        organizations = [];
        selectedOrg = null;
        groupsFetched = false;
        dashboard.style.display = 'none';
        loginGate.style.display = 'flex';
        switchTab('paywall');
        loginUser.value = '';
        loginPass.value = '';
        loginError.textContent = '';
        groupsList.innerHTML = '';
        groupsDetail.innerHTML = '<div class="groups-empty">Select an organization to view details</div>';
        orgSearchInput.value = '';
        resetNotificationState();
      });

      // ── Notifications ──
      function applyNotificationDefaults() {
        notifTitle.value = NOTIFICATION_DEFAULTS.title;
        notifMessage.value = NOTIFICATION_DEFAULTS.message;
        notifDeeplink.value = NOTIFICATION_DEFAULTS.deeplink;
      }

      function resetNotificationState() {
        notificationSelectedUser = null;
        notificationSearchResults = [];
        notifUserQuery.value = '';
        notifResults.innerHTML = '';
        notifSearchStatus.textContent = '';
        notifSendStatus.textContent = '';
        notifSendStatus.className = 'notif-status';
        notifSearchStatus.className = 'notif-status';
        notifSelectedUser.textContent = 'No user selected';
        notifTemplate.value = 'offer_v3';
        applyNotificationDefaults();
      }

      function applyNotificationTemplate(template) {
        if (template === 'blank') {
          notifTitle.value = '';
          notifMessage.value = '';
          notifDeeplink.value = '';
          return;
        }
        applyNotificationDefaults();
      }

      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function renderNotificationSelectedUser() {
        if (!notificationSelectedUser) {
          notifSelectedUser.textContent = 'No user selected';
          return;
        }
        const username = notificationSelectedUser.username || 'Unnamed User';
        const email = notificationSelectedUser.email || 'No email';
        notifSelectedUser.textContent = `Selected: ${username} (${email}) · id ${notificationSelectedUser.id}`;
      }

      function renderNotificationResults() {
        if (!notificationSearchResults.length) {
          notifResults.innerHTML = '';
          return;
        }

        notifResults.innerHTML = notificationSearchResults.map((user) => {
          const selected = notificationSelectedUser && String(notificationSelectedUser.id) === String(user.id) ? ' selected' : '';
          return `<button type="button" class="notif-user-card${selected}" data-user-id="${escapeHtml(user.id)}">
            <div class="notif-user-name">${escapeHtml(user.username || 'Unnamed User')}</div>
            <div class="notif-user-meta">${escapeHtml(user.email || 'No email')} · id ${escapeHtml(user.id)}</div>
          </button>`;
        }).join('');

        notifResults.querySelectorAll('.notif-user-card').forEach((card) => {
          card.addEventListener('click', () => {
            const id = card.dataset.userId;
            const selected = notificationSearchResults.find((u) => String(u.id) === String(id));
            if (!selected) return;
            notificationSelectedUser = selected;
            renderNotificationSelectedUser();
            renderNotificationResults();
          });
        });
      }

      async function searchUsersForNotification() {
        notifSearchStatus.className = 'notif-status';
        notifSearchStatus.textContent = '';

        const query = notifUserQuery.value.trim();
        if (query.length < 2) {
          notifSearchStatus.className = 'notif-status error';
          notifSearchStatus.textContent = 'Enter at least 2 characters to search.';
          return;
        }

        notifSearchBtn.disabled = true;
        notifSearchBtn.textContent = 'Searching…';
        notifSearchStatus.textContent = 'Searching users…';

        try {
          const res = await fetch(`${API}/api/user/search`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${token}`,
            },
            body: JSON.stringify({ query }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Search failed');

          notificationSearchResults = Array.isArray(data.users) ? data.users : [];
          if (!notificationSearchResults.length) {
            notifSearchStatus.className = 'notif-status';
            notifSearchStatus.textContent = 'No users found for that query.';
            notifResults.innerHTML = '';
            return;
          }

          notifSearchStatus.className = 'notif-status success';
          notifSearchStatus.textContent = `Found ${notificationSearchResults.length} user${notificationSearchResults.length === 1 ? '' : 's'}.`;
          renderNotificationResults();
        } catch (e) {
          notificationSearchResults = [];
          notifResults.innerHTML = '';
          notifSearchStatus.className = 'notif-status error';
          notifSearchStatus.textContent = e.message;
        } finally {
          notifSearchBtn.disabled = false;
          notifSearchBtn.textContent = 'Search';
        }
      }

      async function sendManualNotification() {
        notifSendStatus.className = 'notif-status';
        notifSendStatus.textContent = '';

        if (!notificationSelectedUser) {
          notifSendStatus.className = 'notif-status error';
          notifSendStatus.textContent = 'Select a user first.';
          return;
        }

        const title = notifTitle.value.trim();
        const message = notifMessage.value.trim();
        const deeplink = notifDeeplink.value.trim();

        if (!title || !message || !deeplink) {
          notifSendStatus.className = 'notif-status error';
          notifSendStatus.textContent = 'Title, message, and deep link are required.';
          return;
        }

        notifSendBtn.disabled = true;
        notifSendBtn.textContent = 'Sending…';

        try {
          const res = await fetch(`${API}/api/manual-notification`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${token}`,
            },
            body: JSON.stringify({
              userId: notificationSelectedUser.id,
              title,
              message,
              deeplink,
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Failed to send notification');

          notifSendStatus.className = 'notif-status success';
          notifSendStatus.textContent = `Notification sent to ${notificationSelectedUser.email || notificationSelectedUser.id}.`;
        } catch (e) {
          notifSendStatus.className = 'notif-status error';
          notifSendStatus.textContent = e.message;
        } finally {
          notifSendBtn.disabled = false;
          notifSendBtn.textContent = 'Send Notification';
        }
      }

      notifTemplate.addEventListener('change', () => {
        applyNotificationTemplate(notifTemplate.value);
      });
      notifTitleDefaultBtn.addEventListener('click', () => {
        notifTitle.value = NOTIFICATION_DEFAULTS.title;
      });
      notifMessageDefaultBtn.addEventListener('click', () => {
        notifMessage.value = NOTIFICATION_DEFAULTS.message;
      });
      notifDeeplinkDefaultBtn.addEventListener('click', () => {
        notifDeeplink.value = NOTIFICATION_DEFAULTS.deeplink;
      });
      notifSearchBtn.addEventListener('click', searchUsersForNotification);
      notifUserQuery.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') searchUsersForNotification();
      });
      notifSendBtn.addEventListener('click', sendManualNotification);

      // ── ASO Checker (Client-side) ──
      function formatLastUpdate(value) {
        if (!value) return 'N/A';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return 'N/A';
        return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
      }

      function keywordListFromInput() {
        const rows = asoKeywords.value
          .split('\n')
          .map((line) => line.trim())
          .filter(Boolean);

        return [...new Set(rows)];
      }

      async function getRankingForKeyword(keyword, country, appId) {
        const url = `https://itunes.apple.com/search?term=${encodeURIComponent(keyword)}&country=${encodeURIComponent(country)}&entity=software&limit=200`;
        const res = await fetch(url);

        if (!res.ok) {
          throw new Error(`Failed request: ${res.status}`);
        }

        const data = await res.json();
        const results = Array.isArray(data.results) ? data.results : [];

        const topApps = results.slice(0, 7).map((app, idx) => ({
          rank: idx + 1,
          name: app.trackName || 'Unknown App',
          rating: app.averageUserRating ?? 'N/A',
          ratingCount: app.userRatingCount ?? 'N/A',
          lastUpdate: formatLastUpdate(app.currentVersionReleaseDate),
          appId: app.trackId,
          artwork: app.artworkUrl100 || app.artworkUrl60 || '',
        }));

        const index = results.findIndex((app) => Number(app.trackId) === Number(appId));
        const myAppRank = index === -1 ? null : index + 1;

        return { keyword, topApps, myAppRank };
      }

      function renderKeywordResult(result) {
        const section = document.createElement('section');
        section.className = 'aso-keyword';

        const header = document.createElement('div');
        header.className = 'aso-keyword-header';

        const title = document.createElement('div');
        title.className = 'aso-keyword-title';
        title.textContent = `“${result.keyword}”`;

        const badge = document.createElement('div');
        badge.className = `aso-rank-badge${result.myAppRank ? '' : ' missing'}`;
        badge.textContent = result.myAppRank ? `Your app: #${result.myAppRank}` : 'Your app: not in top 200';

        header.appendChild(title);
        header.appendChild(badge);
        section.appendChild(header);

        const list = document.createElement('div');
        list.className = 'aso-app-list';

        result.topApps.forEach((app) => {
          const card = document.createElement('div');
          card.className = 'aso-app-card';

          const image = document.createElement('img');
          image.src = app.artwork || '/MyMeetingsAppLogo.webp';
          image.alt = `${app.name} artwork`;
          image.loading = 'lazy';

          const textWrap = document.createElement('div');

          const rank = document.createElement('div');
          rank.className = 'aso-app-rank';
          rank.textContent = `#${app.rank}`;

          const name = document.createElement('div');
          name.className = 'aso-app-name';
          name.textContent = app.name;

          const meta = document.createElement('div');
          meta.className = 'aso-app-meta';
          meta.textContent = `Rating: ${app.rating} (${app.ratingCount} ratings) · Updated: ${app.lastUpdate}`;

          textWrap.appendChild(rank);
          textWrap.appendChild(name);
          textWrap.appendChild(meta);

          card.appendChild(image);
          card.appendChild(textWrap);
          list.appendChild(card);
        });

        section.appendChild(list);
        asoResults.appendChild(section);
      }

      async function runAsoCheck() {
        const appId = asoAppId.value.trim();
        const country = asoCountry.value.trim().toLowerCase() || 'us';
        const keywords = keywordListFromInput();

        asoStatus.className = 'aso-status';
        asoResults.innerHTML = '';

        if (!keywords.length) {
          asoStatus.className = 'aso-status error';
          asoStatus.textContent = 'Add at least one keyword.';
          return;
        }

        if (!appId || !/^\d+$/.test(appId)) {
          asoStatus.className = 'aso-status error';
          asoStatus.textContent = 'App ID must be numeric.';
          return;
        }

        asoRunBtn.disabled = true;
        asoRunBtn.textContent = 'Running…';

        let successCount = 0;
        let errorCount = 0;

        for (const [index, keyword] of keywords.entries()) {
          asoStatus.textContent = `Checking ${index + 1}/${keywords.length}: ${keyword}`;
          try {
            const result = await getRankingForKeyword(keyword, country, appId);
            renderKeywordResult(result);
            successCount += 1;
          } catch (error) {
            errorCount += 1;
            const message = error instanceof Error ? error.message : 'Unknown error';
            const failed = document.createElement('section');
            failed.className = 'aso-keyword';
            failed.innerHTML = `<div class="aso-keyword-header"><div class="aso-keyword-title">“${keyword}”</div><div class="aso-rank-badge missing">Error</div></div><div class="aso-app-meta">${message}</div>`;
            asoResults.appendChild(failed);
          }
        }

        asoRunBtn.disabled = false;
        asoRunBtn.textContent = 'Run Check';

        if (errorCount) {
          asoStatus.className = 'aso-status error';
          asoStatus.textContent = `Completed with ${errorCount} error${errorCount === 1 ? '' : 's'} (${successCount} successful).`;
          return;
        }

        asoStatus.className = 'aso-status';
        asoStatus.textContent = `Completed ${successCount} keyword${successCount === 1 ? '' : 's'}.`;
      }

      asoRunBtn.addEventListener('click', runAsoCheck);

      // ── Fetch Config ──
      async function fetchConfig() {
        try {
          const res = await fetch(`${API}/api/paywall-config`);
          if (!res.ok) throw new Error('Failed to fetch config');
          const data = await res.json();
          currentConfig = {
            promotion: data.promotion || '',
            promotionVersion: data.promotionVersion ?? 1,
            enableOnboardingRescue: !!data.enableOnboardingRescue,
            isOnboardingHardPaywall: !!data.isOnboardingHardPaywall,
            showDailyPrice: !!data.showDailyPrice,
            showAmountCTA: data.showAmountCTA !== undefined ? !!data.showAmountCTA : true,
          };
          populateForm();
          renderPreview();
        } catch (e) {
          console.error(e);
        }
      }

      function populateForm() {
        cfgPromotion.value = currentConfig.promotion;
        cfgOnboarding.checked = currentConfig.enableOnboardingRescue;
        cfgOnboardingHardPaywall.checked = currentConfig.isOnboardingHardPaywall;
        cfgShowDaily.checked = currentConfig.showDailyPrice;
        cfgShowAmount.checked = currentConfig.showAmountCTA;
        versionBtns.forEach((btn) => {
          btn.classList.toggle('active', Number(btn.dataset.version) === currentConfig.promotionVersion);
        });
      }

      // ── Save Config ──
      async function saveConfig() {
        saveStatus.textContent = '';
        saveStatus.className = 'save-status';
        saveBtn.disabled = true;
        saveBtn.textContent = 'Saving…';
        try {
          const res = await fetch(`${API}/api/paywall-config`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${token}`,
            },
            body: JSON.stringify({
              promotion: currentConfig.promotion,
              promotionVersion: currentConfig.promotionVersion,
              enableOnboardingRescue: currentConfig.enableOnboardingRescue,
              isOnboardingHardPaywall: currentConfig.isOnboardingHardPaywall,
              showDailyPrice: currentConfig.showDailyPrice,
              showAmountCTA: currentConfig.showAmountCTA,
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Save failed');
          saveStatus.textContent = '✓ Configuration saved';
          saveStatus.className = 'save-status success';
        } catch (e) {
          saveStatus.textContent = e.message;
          saveStatus.className = 'save-status error';
        } finally {
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save Configuration';
          setTimeout(() => { saveStatus.textContent = ''; }, 4000);
        }
      }

      saveBtn.addEventListener('click', saveConfig);

      // ── Input Listeners → Update State & Preview ──
      cfgPromotion.addEventListener('input', () => {
        currentConfig.promotion = cfgPromotion.value;
        renderPreview();
      });

      cfgOnboarding.addEventListener('change', () => {
        currentConfig.enableOnboardingRescue = cfgOnboarding.checked;
        renderPreview();
      });

      cfgOnboardingHardPaywall.addEventListener('change', () => {
        currentConfig.isOnboardingHardPaywall = cfgOnboardingHardPaywall.checked;
      });

      cfgShowDaily.addEventListener('change', () => {
        currentConfig.showDailyPrice = cfgShowDaily.checked;
        renderPreview();
      });

      cfgShowAmount.addEventListener('change', () => {
        currentConfig.showAmountCTA = cfgShowAmount.checked;
        renderPreview();
      });

      versionBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          currentConfig.promotionVersion = Number(btn.dataset.version);
          versionBtns.forEach((b) => b.classList.toggle('active', b === btn));
          renderPreview();
        });
      });

      // ── Render Preview ──
      function renderPreview() {
        renderFeatures();
        renderMarquee();
        renderOptions();
        renderCTA();
      }

      let currentFeatureIndex = 0;
      let featureAutoTimer = null;

      function renderFeatures() {
        const scroller = document.getElementById('pw-feature-scroller');
        const dots = document.getElementById('pw-dots');
        scroller.innerHTML = FEATURES.map(
          (f, i) => `<div class="pw-feature-card${i === currentFeatureIndex ? ' active' : ''}">
            <div class="fc-icon-title"><span class="fc-icon">${f.icon}</span><span class="fc-title">${f.title}</span></div>
            <div class="fc-desc">${f.desc}</div>
          </div>`
        ).join('');
        dots.innerHTML = FEATURES.map(
          (_, i) => `<div class="pw-dot${i === currentFeatureIndex ? ' active' : ''}" data-idx="${i}"></div>`
        ).join('');

        // Click on dots to jump
        dots.querySelectorAll('.pw-dot').forEach((dot) => {
          dot.addEventListener('click', () => {
            currentFeatureIndex = Number(dot.dataset.idx);
            showFeature(currentFeatureIndex);
            resetFeatureTimer();
          });
        });

        // Auto-advance
        resetFeatureTimer();
      }

      function showFeature(idx) {
        const cards = document.querySelectorAll('.pw-feature-card');
        const dots = document.querySelectorAll('.pw-dot');
        cards.forEach((c, i) => c.classList.toggle('active', i === idx));
        dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      }

      function resetFeatureTimer() {
        if (featureAutoTimer) clearInterval(featureAutoTimer);
        featureAutoTimer = setInterval(() => {
          currentFeatureIndex = (currentFeatureIndex + 1) % FEATURES.length;
          showFeature(currentFeatureIndex);
        }, 3500);
      }

      function renderMarquee() {
        const wrap = document.getElementById('pw-marquee-wrap');
        const text = document.getElementById('pw-marquee-text');
        if (currentConfig.promotion && currentConfig.promotion.trim()) {
          wrap.classList.remove('hidden');
          text.textContent = currentConfig.promotion;
        } else {
          wrap.classList.add('hidden');
        }
      }

      function renderOptions() {
        const container = document.getElementById('pw-options');
        const v = currentConfig.promotionVersion;
        const prices = PRICES[v] || PRICES[1];
        const showDaily = currentConfig.showDailyPrice;

        function formatPrice(amount) {
          return '$' + amount.toFixed(2);
        }

        function priceText(type) {
          if (showDaily) {
            const daily = type === 'annual' ? prices.annual / 365 : prices.monthly / 30;
            return `Free trial for 3 days — then ${formatPrice(daily)}/day`;
          }
          if (type === 'annual') {
            return `Free trial for 3 days — then ${formatPrice(prices.annual)}/year`;
          }
          return `Free trial for 3 days — then ${formatPrice(prices.monthly)}/month`;
        }

        container.innerHTML = `
          <div class="pw-option ${selectedPlan === 'monthly' ? 'selected' : ''}" data-plan="monthly">
            <div>
              <div class="opt-name">Monthly Plan</div>
              <div class="opt-price">${priceText('monthly')}</div>
            </div>
            <div class="opt-check">✓</div>
          </div>
          <div class="pw-option ${selectedPlan === 'annual' ? 'selected' : ''}" data-plan="annual">
            <div>
              <div class="opt-name">Annual Plan</div>
              <div class="opt-price">${priceText('annual')}</div>
            </div>
            <div class="opt-check">✓</div>
          </div>
        `;

        container.querySelectorAll('.pw-option').forEach((el) => {
          el.addEventListener('click', () => {
            selectedPlan = el.dataset.plan;
            renderOptions();
            renderCTA();
          });
        });
      }

      function renderCTA() {
        const btn = document.getElementById('pw-cta-btn');
        const sub = document.getElementById('pw-cta-sub');
        const v = currentConfig.promotionVersion;
        const prices = PRICES[v] || PRICES[1];

        if (currentConfig.showAmountCTA) {
          // showAmountCTA always shows the product's full price, never daily
          const price = selectedPlan === 'annual' ? prices.annual : prices.monthly;
          const period = selectedPlan === 'annual' ? 'year' : 'month';
          btn.textContent = `3 Day Trial then $${price.toFixed(2)}/${period}`;
        } else {
          btn.textContent = 'Try for $0.00';
        }

        // Cancellation date
        const cancel = new Date();
        cancel.setDate(cancel.getDate() + 3);
        const day = cancel.getDate();
        const suffix = daySuffix(day);
        const month = cancel.toLocaleString('en-US', { month: 'short' });
        sub.textContent = `Free cancellation before ${month} ${day}${suffix}`;
      }

      function daySuffix(d) {
        if (d >= 11 && d <= 13) return 'th';
        switch (d % 10) {
          case 1: return 'st';
          case 2: return 'nd';
          case 3: return 'rd';
          default: return 'th';
        }
      }

      if (!asoKeywords.value.trim()) {
        asoKeywords.value = ASO_DEFAULT_KEYWORDS.join('\n');
      }

      // Initial feature render (for static display before login)
      renderPreview();
      resetNotificationState();

      // ── Groups / Organizations ──
      const AVATAR_COLORS = [
        '#E57373','#F06292','#BA68C8','#9575CD','#7986CB',
        '#64B5F6','#4FC3F7','#4DD0E1','#4DB6AC','#81C784',
        '#AED581','#DCE775','#FFD54F','#FFB74D','#FF8A65',
        '#A1887F','#90A4AE','#7E57C2','#5C6BC0','#26A69A',
      ];

      function avatarColor(id) {
        let hash = 0;
        const s = String(id);
        for (let i = 0; i < s.length; i++) {
          hash = s.charCodeAt(i) + ((hash << 5) - hash);
        }
        return AVATAR_COLORS[Math.abs(hash) % AVATAR_COLORS.length];
      }

      function avatarHTML(member) {
        if (member.profileImageUrl) {
          return `<img class="member-avatar" src="${member.profileImageUrl}" alt="${member.username}" />`;
        }
        const color = avatarColor(member.id);
        const initial = (member.username || '?')[0].toUpperCase();
        return `<div class="member-avatar-fallback" style="background:${color}">${initial}</div>`;
      }

      function orgLogoHTML(org, cls) {
        if (org.logoUrl) {
          return `<img class="${cls}" src="${org.logoUrl}" alt="${org.name}" />`;
        }
        const color = avatarColor(org.id);
        const initial = (org.name || '?')[0].toUpperCase();
        const size = cls === 'org-detail-logo' ? 'width:56px;height:56px;border-radius:14px;font-size:1.4rem;' : 'width:38px;height:38px;border-radius:10px;font-size:1rem;';
        return `<div class="member-avatar-fallback" style="background:${color};${size}">${initial}</div>`;
      }

      async function fetchOrganizations() {
        groupsList.innerHTML = '<div class="groups-loading">Loading organizations…</div>';
        try {
          const res = await fetch(`${API}/api/management/organizations`, {
            headers: { Authorization: `Bearer ${token}` },
          });
          if (!res.ok) throw new Error('Failed to fetch organizations');
          organizations = await res.json();
          groupsFetched = true;
          renderOrgList();
        } catch (e) {
          groupsList.innerHTML = `<div class="groups-loading" style="color:#f87171">${e.message}</div>`;
        }
      }

      function renderOrgList() {
        const query = orgSearchInput.value.trim().toLowerCase();
        const filtered = organizations.filter((org) => {
          if (!query) return true;
          return (org.name || '').toLowerCase().includes(query)
            || (org.orgCode || '').toLowerCase().includes(query);
        });

        if (!filtered.length) {
          groupsList.innerHTML = `<div class="groups-loading">${query ? 'No matching organizations' : 'No organizations found'}</div>`;
          return;
        }

        groupsList.innerHTML = filtered.map((org) => {
          const active = selectedOrg && selectedOrg.id === org.id ? ' active' : '';
          const badge = org.isPublic
            ? '<span class="org-visibility-badge public">Public</span>'
            : '<span class="org-visibility-badge private">Private</span>';
          return `<button class="org-card${active}" data-org-id="${org.id}">
            ${orgLogoHTML(org, 'org-card-logo')}
            <div class="org-card-info">
              <div class="org-card-name">${org.name || 'Unnamed'}</div>
              <div class="org-card-meta">${badge}</div>
            </div>
          </button>`;
        }).join('');

        groupsList.querySelectorAll('.org-card').forEach((card) => {
          card.addEventListener('click', () => {
            fetchOrgDetail(card.dataset.orgId);
          });
        });
      }

      orgSearchInput.addEventListener('input', renderOrgList);

      async function fetchOrgDetail(id) {
        groupsDetail.innerHTML = '<div class="groups-loading">Loading…</div>';
        try {
          const res = await fetch(`${API}/api/management/organizations/${encodeURIComponent(id)}`, {
            headers: { Authorization: `Bearer ${token}` },
          });
          if (!res.ok) throw new Error('Failed to fetch organization details');
          selectedOrg = await res.json();
          renderOrgList();
          renderOrgDetail();
        } catch (e) {
          groupsDetail.innerHTML = `<div class="groups-loading" style="color:#f87171">${e.message}</div>`;
        }
      }

      function renderOrgDetail() {
        if (!selectedOrg) return;
        const o = selectedOrg;
        const members = o.members || [];

        groupsDetail.innerHTML = `
          <div class="org-detail-header">
            ${orgLogoHTML(o, 'org-detail-logo')}
            <div class="org-detail-title">
              <h2>${o.name || 'Unnamed Organization'}</h2>
              <div class="org-detail-code">${o.orgCode || '—'}</div>
            </div>
          </div>

          <div class="org-settings-section">
            <h3>Settings</h3>
            <div class="org-form-field">
              <label>Name</label>
              <input type="text" id="org-edit-name" value="${(o.name || '').replace(/"/g, '&quot;')}" />
            </div>
            <div class="org-form-field">
              <label>Description</label>
              <textarea id="org-edit-desc">${o.description || ''}</textarea>
            </div>
            <div class="org-form-field">
              <label>Logo URL</label>
              <input type="text" id="org-edit-logo" value="${(o.logoUrl || '').replace(/"/g, '&quot;')}" placeholder="https://…" />
            </div>

            <div class="org-toggle-row">
              <div class="org-toggle-info">
                <div class="org-toggle-label">Public</div>
                <div class="org-toggle-desc">Allow anyone to discover and join this organization</div>
              </div>
              <label class="toggle">
                <input type="checkbox" id="org-edit-public" ${o.isPublic ? 'checked' : ''} />
                <span class="slider"></span>
              </label>
            </div>

            <div class="org-toggle-row">
              <div class="org-toggle-info">
                <div class="org-toggle-label">New Users Get Full Access</div>
                <div class="org-toggle-desc">Grant full access to new members automatically</div>
              </div>
              <label class="toggle">
                <input type="checkbox" id="org-edit-full-access" ${o.newUsersGetFullAccess ? 'checked' : ''} />
                <span class="slider"></span>
              </label>
            </div>

            <div class="org-save-bar">
              <button class="org-save-btn" id="org-save-btn">Save Settings</button>
              <span class="org-save-status" id="org-save-status"></span>
            </div>
          </div>

          <div class="org-settings-section">
            <h3>Members (${members.length})</h3>
            <div class="members-grid" id="members-grid">
              ${members.map((m) => `
                <div class="member-card">
                  ${avatarHTML(m)}
                  <div class="member-info">
                    <div class="member-username">${m.username || '—'}</div>
                    <div class="member-reason">${m.reasonForGettingSober || ''}</div>
                  </div>
                  <select class="role-select" data-member-id="${m.id}">
                    <option value="admin"${m.role === 'admin' ? ' selected' : ''}>Admin</option>
                    <option value="member"${m.role === 'member' ? ' selected' : ''}>Member</option>
                    <option value="viewer"${m.role === 'viewer' ? ' selected' : ''}>Viewer</option>
                  </select>
                </div>
              `).join('')}
            </div>
          </div>
        `;

        // Save settings
        document.getElementById('org-save-btn').addEventListener('click', saveOrgSettings);

        // Role dropdowns
        document.querySelectorAll('#members-grid .role-select').forEach((sel) => {
          sel.addEventListener('change', () => {
            updateMemberRole(o.id, sel.dataset.memberId, sel.value, sel);
          });
        });
      }

      async function saveOrgSettings() {
        const btn = document.getElementById('org-save-btn');
        const status = document.getElementById('org-save-status');
        btn.disabled = true;
        btn.textContent = 'Saving…';
        status.textContent = '';
        status.className = 'org-save-status';

        try {
          const body = {
            name: document.getElementById('org-edit-name').value.trim(),
            description: document.getElementById('org-edit-desc').value.trim(),
            logoUrl: document.getElementById('org-edit-logo').value.trim(),
            isPublic: document.getElementById('org-edit-public').checked,
            newUsersGetFullAccess: document.getElementById('org-edit-full-access').checked,
          };

          const res = await fetch(`${API}/api/management/organizations/${encodeURIComponent(selectedOrg.id)}`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${token}`,
            },
            body: JSON.stringify(body),
          });
          if (!res.ok) {
            const data = await res.json();
            throw new Error(data.error || 'Save failed');
          }

          // Update local state
          Object.assign(selectedOrg, body);
          const idx = organizations.findIndex((o) => o.id === selectedOrg.id);
          if (idx !== -1) Object.assign(organizations[idx], body);

          status.textContent = '✓ Saved';
          status.className = 'org-save-status success';
          renderOrgList();
        } catch (e) {
          status.textContent = e.message;
          status.className = 'org-save-status error';
        } finally {
          btn.disabled = false;
          btn.textContent = 'Save Settings';
          setTimeout(() => { status.textContent = ''; }, 4000);
        }
      }

      async function updateMemberRole(orgId, memberId, role, selectEl) {
        selectEl.disabled = true;
        try {
          const res = await fetch(`${API}/api/management/organizations/${encodeURIComponent(orgId)}/members/${encodeURIComponent(memberId)}`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${token}`,
            },
            body: JSON.stringify({ role }),
          });
          if (!res.ok) {
            const data = await res.json();
            throw new Error(data.error || 'Update failed');
          }
          // Update local member state
          const member = (selectedOrg.members || []).find((m) => String(m.id) === String(memberId));
          if (member) member.role = role;
        } catch (e) {
          alert('Failed to update role: ' + e.message);
          // Revert dropdown
          const member = (selectedOrg.members || []).find((m) => String(m.id) === String(memberId));
          if (member) selectEl.value = member.role;
        } finally {
          selectEl.disabled = false;
        }
      }
    </script>
  </body>
</html>
