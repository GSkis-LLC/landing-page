      .org-visibility-badge.public {
        background: rgba(42,157,143,0.15);
        color: #5eead4;
      }

      .org-visibility-badge.private {
        background: rgba(248,113,113,0.12);
        color: #fca5a5;
      }

      .groups-detail {
