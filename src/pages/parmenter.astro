---
export const prerender = false;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Parmenter</title>
    <link rel="icon" type="image/x-icon" href="/myMeetings.ico" />
    <style is:global>
      @font-face {
        font-family: 'SF Pro Display';
        src: url('/fonts/SFPRODISPLAYREGULAR.OTF') format('opentype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'SF Pro Display';
        src: url('/fonts/SFPRODISPLAYBOLD.OTF') format('opentype');
        font-weight: bold;
        font-style: normal;
        font-display: swap;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #0f1117;
        color: #e2e8f0;
        min-height: 100vh;
      }

      /* ── Login Gate ── */
      #login-gate {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #0f1117 0%, #1a1d2e 100%);
      }

      .login-card {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        padding: 3rem 2.5rem;
        width: 100%;
        max-width: 400px;
        backdrop-filter: blur(20px);
        text-align: center;
      }

      .login-card h1 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
        color: #fff;
      }

      .login-card .subtitle {
        color: #94a3b8;
        font-size: 0.95rem;
        margin-bottom: 2rem;
      }

      .login-card .form-group {
        margin-bottom: 1rem;
        text-align: left;
      }

      .login-card label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 0.35rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .login-card input[type="text"],
      .login-card input[type="password"] {
        width: 100%;
        padding: 0.75rem 1rem;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.06);
        color: #fff;
        font-size: 1rem;
        font-family: inherit;
        outline: none;
        transition: border-color 0.2s;
      }

      .login-card input:focus {
        border-color: #2A9D8F;
      }

      .login-card .error-msg {
        color: #f87171;
        font-size: 0.85rem;
        margin-bottom: 0.75rem;
        min-height: 1.25rem;
      }

      .login-btn {
        width: 100%;
        padding: 0.8rem;
        border: none;
        border-radius: 10px;
        background: #2A9D8F;
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: background 0.2s;
      }

      .login-btn:hover { background: #21867A; }
      .login-btn:disabled { opacity: 0.6; cursor: not-allowed; }

      /* ── Dashboard ── */
      #dashboard {
        display: none;
        height: 100vh;
        flex-direction: column;
      }

      .dash-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: rgba(15,17,23,0.85);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .dash-header h1 {
        font-size: 1.1rem;
        font-weight: 700;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .dash-header h1 span {
        font-size: 0.7rem;
        font-weight: 500;
        background: #2A9D8F;
        color: #fff;
        padding: 0.15rem 0.5rem;
        border-radius: 6px;
      }

      .logout-btn {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.1);
        color: #94a3b8;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-family: inherit;
        cursor: pointer;
        transition: all 0.2s;
      }
      .logout-btn:hover { background: rgba(255,255,255,0.12); color: #fff; }

      .tab-bar {
        display: flex;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: rgba(15,17,23,0.8);
      }

      .tab-btn {
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 8px;
        background: rgba(255,255,255,0.04);
        color: #94a3b8;
        padding: 0.45rem 0.9rem;
        font-size: 0.85rem;
        font-family: inherit;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
      }

      .tab-btn:hover {
        border-color: rgba(255,255,255,0.22);
        color: #cbd5e1;
      }

      .tab-btn.active {
        background: rgba(42,157,143,0.15);
        border-color: #2A9D8F;
        color: #5eead4;
      }

      .tab-panel {
        display: none;
        flex: 1;
        min-height: 0;
      }

      .tab-panel.active {
        display: block;
      }

      .dash-body {
        display: grid;
        grid-template-columns: 420px 1fr;
        height: 100%;
        overflow: hidden;
      }

      /* ── ASO Tab ── */
      .aso-panel {
        height: 100%;
        overflow-y: auto;
        padding: 1.5rem;
      }

      .aso-layout {
        display: grid;
        grid-template-columns: minmax(320px, 420px) 1fr;
        gap: 1rem;
      }

      .aso-controls,
      .aso-results-wrap {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 1rem;
      }

      .aso-controls h3,
      .aso-results-wrap h3 {
        font-size: 0.8rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 0.75rem;
      }

      .aso-field {
        margin-bottom: 0.8rem;
      }

      .aso-field label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 0.35rem;
      }

      .aso-field textarea,
      .aso-field input {
        width: 100%;
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 10px;
        background: rgba(255,255,255,0.06);
        color: #fff;
        font-size: 0.9rem;
        font-family: inherit;
        outline: none;
        padding: 0.7rem 0.8rem;
      }

      .aso-field textarea {
        min-height: 210px;
        resize: vertical;
        line-height: 1.35;
      }

      .aso-field textarea:focus,
      .aso-field input:focus {
        border-color: #2A9D8F;
      }

      .aso-inline {
        display: grid;
        grid-template-columns: 1fr 120px;
        gap: 0.65rem;
      }

      .aso-run-btn {
        width: 100%;
        border: none;
        border-radius: 10px;
        background: #2A9D8F;
        color: #fff;
        font-size: 0.9rem;
        font-family: inherit;
        font-weight: 600;
        cursor: pointer;
        padding: 0.75rem;
      }

      .aso-run-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .aso-status {
        margin-top: 0.5rem;
        min-height: 1.2rem;
        font-size: 0.8rem;
        color: #94a3b8;
      }

      .aso-status.error { color: #f87171; }

      .aso-results {
        display: grid;
        gap: 0.8rem;
      }

      .aso-keyword {
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        background: rgba(255,255,255,0.03);
        padding: 0.9rem;
      }

      .aso-keyword-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.7rem;
        margin-bottom: 0.75rem;
      }

      .aso-keyword-title {
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
      }

      .aso-rank-badge {
        border-radius: 999px;
        border: 1px solid rgba(42,157,143,0.6);
        background: rgba(42,157,143,0.12);
        color: #5eead4;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.25rem 0.55rem;
        white-space: nowrap;
      }

      .aso-rank-badge.missing {
        border-color: rgba(248,113,113,0.6);
        background: rgba(248,113,113,0.12);
        color: #fca5a5;
      }

      .aso-app-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 0.55rem;
      }

      .aso-app-card {
        display: grid;
        grid-template-columns: 56px 1fr;
        gap: 0.55rem;
        align-items: center;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        background: rgba(255,255,255,0.04);
        padding: 0.55rem;
      }

      .aso-app-card img {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        object-fit: cover;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.06);
      }

      .aso-app-rank {
        font-size: 0.7rem;
        color: #5eead4;
        font-weight: 700;
        margin-bottom: 0.1rem;
      }

      .aso-app-name {
        font-size: 0.83rem;
        color: #fff;
        font-weight: 600;
        line-height: 1.2;
      }

      .aso-app-meta {
        font-size: 0.72rem;
        color: #94a3b8;
        line-height: 1.25;
        margin-top: 0.2rem;
      }

      /* ── Left Panel: Config Controls ── */
      .config-panel {
        padding: 1.5rem;
        overflow-y: auto;
        border-right: 1px solid rgba(255,255,255,0.08);
      }

      .config-section {
        margin-bottom: 1.75rem;
      }

      .config-section h3 {
        font-size: 0.75rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 0.75rem;
      }

      .config-field {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 0.75rem;
      }

      .config-field .field-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.35rem;
      }

      .config-field .field-label {
        font-size: 0.95rem;
        font-weight: 600;
        color: #e2e8f0;
      }

      .config-field .field-desc {
        font-size: 0.8rem;
        color: #64748b;
        line-height: 1.4;
      }

      .config-field input[type="text"] {
        width: 100%;
        padding: 0.6rem 0.75rem;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.06);
        color: #fff;
        font-size: 0.9rem;
        font-family: inherit;
        outline: none;
        margin-top: 0.5rem;
        transition: border-color 0.2s;
      }

      .config-field input[type="text"]:focus { border-color: #2A9D8F; }

      /* Onboarding Rescue Preview */
      .rescue-preview {
        margin-top: 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .rescue-notif {
        display: flex;
        gap: 0.6rem;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 0.65rem 0.75rem;
      }

      .rescue-notif .notif-icon {
        font-size: 1.2rem;
        flex-shrink: 0;
        margin-top: 0.1rem;
      }

      .rescue-notif .notif-body {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .rescue-notif .notif-timing {
        font-size: 0.65rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        font-weight: 600;
      }

      .rescue-notif .notif-body strong {
        font-size: 0.82rem;
        color: #e2e8f0;
      }

      .rescue-notif .notif-body p {
        font-size: 0.75rem;
        color: #94a3b8;
        line-height: 1.35;
        margin: 0;
      }

      .rescue-note {
        font-size: 0.7rem;
        color: #64748b;
        margin-top: 0.15rem;
      }

      .rescue-note code {
        font-size: 0.68rem;
        background: rgba(255,255,255,0.06);
        padding: 0.1rem 0.35rem;
        border-radius: 4px;
        color: #5eead4;
      }

      /* Toggle */
      .toggle {
        position: relative;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
      }

      .toggle input { opacity: 0; width: 0; height: 0; }

      .toggle .slider {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.12);
        border-radius: 24px;
        cursor: pointer;
        transition: background 0.2s;
      }

      .toggle .slider::before {
        content: '';
        position: absolute;
        width: 18px; height: 18px;
        border-radius: 50%;
        background: #fff;
        top: 3px; left: 3px;
        transition: transform 0.2s;
      }

      .toggle input:checked + .slider { background: #2A9D8F; }
      .toggle input:checked + .slider::before { transform: translateX(20px); }

      /* Version Selector */
      .version-options {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.5rem;
      }

      .version-btn {
        flex: 1;
        padding: 0.6rem 0.5rem;
        border-radius: 10px;
        border: 2px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04);
        color: #94a3b8;
        font-size: 0.8rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        text-align: center;
        transition: all 0.2s;
      }

      .version-btn:hover { border-color: rgba(255,255,255,0.2); }

      .version-btn.active {
        border-color: #2A9D8F;
        background: rgba(42,157,143,0.12);
        color: #2A9D8F;
      }

      .version-btn .price-label {
        display: block;
        font-size: 0.7rem;
        font-weight: 400;
        color: #64748b;
        margin-top: 0.2rem;
      }

      .version-btn.active .price-label { color: #5eead4; }

      /* Save Button */
      .save-bar {
        padding: 1rem 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.08);
        position: sticky;
        bottom: 0;
        background: rgba(15,17,23,0.95);
        backdrop-filter: blur(12px);
      }

      .save-btn {
        width: 100%;
        padding: 0.75rem;
        border: none;
        border-radius: 10px;
        background: #2A9D8F;
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: all 0.2s;
      }

      .save-btn:hover { background: #21867A; }
      .save-btn:disabled { opacity: 0.5; cursor: not-allowed; }

      .save-status {
        text-align: center;
        font-size: 0.8rem;
        margin-top: 0.5rem;
        min-height: 1.2rem;
      }

      .save-status.success { color: #4ade80; }
      .save-status.error { color: #f87171; }

      /* ── Right Panel: Preview ── */
      .preview-panel {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #1a1d2e;
        overflow: auto;
        padding: 2rem;
      }

      .iphone-frame {
        width: 375px;
        height: 812px;
        border-radius: 50px;
        border: 6px solid #2a2d3a;
        background: #000;
        position: relative;
        overflow: hidden;
        box-shadow: 0 0 0 2px #1a1d2e, 0 25px 60px rgba(0,0,0,0.5);
        flex-shrink: 0;
      }

      .iphone-notch {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 160px;
        height: 30px;
        background: #000;
        border-radius: 0 0 20px 20px;
        z-index: 10;
      }

      .paywall-screen {
        width: 100%;
        height: 100%;
        overflow-y: auto;
        overflow-x: hidden;
        background: linear-gradient(135deg, rgba(42,157,143,0.85) 0%, rgba(90,125,154,0.85) 50%, rgba(55,178,166,0.85) 100%);
        display: flex;
        flex-direction: column;
        padding: 50px 20px 20px;
      }

      .paywall-screen::-webkit-scrollbar { width: 0; }

      /* ── Paywall Inner Styles ── */
      .pw-header {
        text-align: center;
        margin-bottom: 12px;
      }

      .pw-logo-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-bottom: 16px;
      }

      .pw-logo-icon {
        width: 40px; height: 40px;
        border-radius: 10px;
        object-fit: cover;
      }

      .pw-pro-label {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
      }

      .pw-close {
        position: absolute;
        top: 52px; right: 24px;
        color: rgba(255,255,255,0.7);
        font-size: 18px;
        cursor: default;
      }

      .pw-title {
        font-size: 24px;
        font-weight: 700;
        color: #fff;
        line-height: 1.2;
        margin-bottom: 8px;
        font-family: Georgia, 'Times New Roman', serif;
      }

      .pw-subtitle {
        font-size: 14px;
        color: rgba(255,255,255,0.75);
        line-height: 1.45;
      }

      /* Feature Carousel — paged (one card at a time) */
      .pw-features {
        margin: 12px 0;
        position: relative;
      }

      .pw-feature-scroller {
        position: relative;
        overflow: hidden;
        height: 150px;
      }

      .pw-feature-card {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 16px;
        padding: 20px 18px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
      }

      .pw-feature-card.active {
        opacity: 1;
        pointer-events: auto;
      }

      .pw-feature-card .fc-icon-title {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-bottom: 8px;
      }

      .pw-feature-card .fc-icon {
        font-size: 22px;
      }

      .pw-feature-card .fc-title {
        font-size: 14px;
        font-weight: 600;
        color: #fff;
      }

      .pw-feature-card .fc-desc {
        font-size: 12.5px;
        color: rgba(255,255,255,0.85);
        line-height: 1.45;
        padding: 0 4px;
      }

      .pw-dots {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 10px;
      }

      .pw-dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        cursor: pointer;
        transition: background 0.2s;
      }
      .pw-dot.active { background: #fff; }

      /* Spacer */
      .pw-spacer { flex: 1; min-height: 8px; }

      /* Promotion Marquee */
      .pw-marquee-wrap {
        overflow: hidden;
        margin-bottom: 8px;
        height: 20px;
      }

      .pw-marquee-wrap.hidden { display: none; }

      .pw-marquee {
        display: inline-block;
        white-space: nowrap;
        animation: marquee 12s linear infinite;
        font-size: 13px;
        font-weight: 700;
        color: rgba(233,196,106,0.85);
      }

      @keyframes marquee {
        0% { transform: translateX(100%); }
        100% { transform: translateX(-100%); }
      }

      .pw-trusted {
        text-align: center;
        font-size: 13px;
        color: rgba(255,255,255,0.7);
        margin-bottom: 10px;
      }

      /* Subscription Options */
      .pw-option {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 2px solid transparent;
        border-radius: 18px;
        padding: 14px 16px;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        transition: all 0.2s;
      }

      .pw-option.selected {
        border-color: #2A9D8F;
        background: rgba(42,157,143,0.18);
      }

      .pw-option .opt-name {
        font-size: 15px;
        font-weight: 600;
        color: #fff;
      }

      .pw-option .opt-price {
        font-size: 12px;
        color: rgba(255,255,255,0.8);
        margin-top: 2px;
      }

      .pw-option .opt-check {
        width: 22px; height: 22px;
        border-radius: 50%;
        background: #2A9D8F;
        display: flex; align-items: center; justify-content: center;
        color: #fff;
        font-size: 13px;
        opacity: 0;
        transition: opacity 0.2s;
      }

      .pw-option.selected .opt-check { opacity: 1; }

      /* CTA */
      .pw-cta-btn {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 12px;
        background: #2A9D8F;
        color: #fff;
        font-size: 15px;
        font-weight: 700;
        font-family: inherit;
        text-align: center;
        margin-top: 10px;
        cursor: default;
