      .org-save-btn:hover { background: #21867A; }
      .org-save-btn:disabled { opacity: 0.5; cursor: not-allowed; }

      .org-save-status {
        font-size: 0.8rem;
        min-height: 1.2rem;
      }

      .org-save-status.success { color: #4ade80; }
      .org-save-status.error { color: #f87171; }

      /* Members */
      .members-grid {
        display: grid;
        gap: 0.5rem;
      }

      .member-card {
        display: grid;
        grid-template-columns: 40px 1fr auto;
        gap: 0.75rem;
        align-items: center;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 0.65rem 0.85rem;
