      .org-form-field textarea {
        min-height: 80px;
        resize: vertical;
        line-height: 1.4;
      }

      .org-form-field input:focus,
      .org-form-field textarea:focus {
        border-color: #2A9D8F;
      }

      .org-toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
      }

      .org-toggle-info {
        flex: 1;
      }

      .org-toggle-label {
        font-size: 0.9rem;
        font-weight: 600;
        color: #e2e8f0;
      }

      .org-toggle-desc {
        font-size: 0.75rem;
        color: #64748b;
        margin-top: 0.15rem;
      }

      .org-save-bar {
