      /* ── Responsive ── */
      @media (max-width: 900px) {
        .dash-body {
          grid-template-columns: 1fr;
          grid-template-rows: auto 1fr;
          height: auto;
        }
        .config-panel { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); max-height: 50vh; }
        .preview-panel { min-height: 900px; }
        .aso-layout {
          grid-template-columns: 1fr;
        }
        .aso-inline {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
