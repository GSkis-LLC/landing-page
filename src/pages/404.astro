---
import Header from '../components/Header.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/x-icon" href="/myMeetings.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>404: Page Not Found | MyMeetings</title>
		<meta name="description" content="We couldn’t find that page. Get back on track with MyMeetings and find AA meetings near you." />
		<meta name="robots" content="noindex, follow" />
		<link rel="canonical" href="https://mymeetings.co/404" />
		<style>
			@font-face {
				font-family: 'SF Pro Display';
				src: url('/fonts/SFPRODISPLAYREGULAR.OTF') format('opentype');
				font-display: swap;
			}

			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				line-height: 1.6;
				color: #333;
				background: linear-gradient(180deg, #F8F9FA 0%, #FFFFFF 100%);
				min-height: 100vh;
			}

			.container {
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 2rem;
			}

			.hero {
				padding: 3rem 0 2rem;
				text-align: center;
			}

			.hero h1 {
				font-size: 3rem;
				font-weight: bold;
				color: #2A2A2A;
				margin-bottom: 1rem;
			}

			.highlight-word {
				background: linear-gradient(135deg, #2A9D8F 0%, #5A7D9A 50%, #E9C46A 100%);
				background-size: 200% 200%;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				animation: gradientShift 3s ease-in-out infinite;
			}

			.hero p {
				font-size: 1.2rem;
				color: #4a5568;
				max-width: 700px;
				margin: 0 auto 2rem;
			}

			.inline-link {
				color: #2A9D8F;
				font-weight: 600;
				text-decoration: none;
				border-bottom: 2px solid rgba(42, 157, 143, 0.3);
				transition: color 0.2s ease, border-color 0.2s ease;
			}

			.inline-link:hover,
			.inline-link:focus-visible {
				color: #21867A;
				border-color: rgba(33, 134, 122, 0.6);
				outline: none;
			}

			.card {
				background: white;
				border-radius: 16px;
				padding: 2rem;
				box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
				margin: 1.5rem auto 2.5rem;
				max-width: 800px;
				text-align: left;
			}

			.card h2 {
				font-size: 1.6rem;
				color: #2A2A2A;
				margin-bottom: 0.75rem;
			}

			.card ul {
				list-style: none;
				padding: 0;
				margin: 1rem 0 0;
			}

			.card li {
				padding: 0.5rem 0;
				color: #4a5568;
				border-bottom: 1px solid #e2e8f0;
			}

			.card li:last-child {
				border-bottom: none;
			}

			.actions {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 1rem;
				margin-top: 2rem;
			}

			.primary-button,
			.secondary-button {
				display: inline-flex;
				align-items: center;
				gap: 0.75rem;
				padding: 1rem 2rem;
				border-radius: 12px;
				text-decoration: none;
				font-weight: 600;
				font-size: 1rem;
				transition: all 0.3s ease;
			}

			.primary-button {
				background: #2A9D8F;
				color: white;
				box-shadow: 0 6px 12px rgba(42, 157, 143, 0.25);
				border: 1px solid #207F74;
			}

			.primary-button:hover {
				background: #21867A;
				transform: translateY(-2px);
				box-shadow: 0 8px 16px rgba(42, 157, 143, 0.35);
			}

			.secondary-button {
				background: #F1F5F9;
				color: #1f2937;
				border: 1px solid #E2E8F0;
			}

			.secondary-button:hover {
				background: #E2E8F0;
				transform: translateY(-2px);
			}

			.footer-note {
				text-align: center;
				color: #5A7D9A;
				font-size: 0.95rem;
				margin-bottom: 3rem;
			}

			@keyframes gradientShift {
				0%, 100% { background-position: 0% 50%; }
				50% { background-position: 100% 50%; }
			}

			@media (max-width: 768px) {
				.container {
					padding: 0 1rem;
				}

				.hero h1 {
					font-size: 2.3rem;
				}

				.hero p {
					font-size: 1.05rem;
				}

				.card {
					padding: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="container">
					<h1>404: You’re on the <span class="highlight-word">wrong path</span></h1>
					<p>This page can’t be found, but you can still get back on track in a few easy steps.</p>

					<div class="card">
						<h2>Here are some helpful next steps</h2>
						<ul>
							<li>Check the URL for any typos, then try again.</li>
							<li>Head to the <a class="inline-link" href="/meetings">meeting finder</a> to get back to today’s schedule.</li>
							<li>Explore meetings by state or city and reconnect with your community.</li>
							<li>If you were looking for a meeting, use the search in the header.</li>
						</ul>
					</div>

					<div class="actions">
						<a class="primary-button" href="/myMeetings">
							Back To Home
						</a>
						<a class="secondary-button" href="/meetings">
							Find Meetings
						</a>
					</div>
				</div>
			</section>
			<p class="footer-note">You’re not alone. we’ll help you find the next meeting.</p>
		</main>
	</body>
</html>
