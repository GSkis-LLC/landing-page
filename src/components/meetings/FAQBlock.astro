---
const { city, stateFull, meetingCount } = Astro.props;

const faqs = [
  {
    question: `How many AA meetings are in ${city}?`,
    answer: `There are over ${meetingCount} AA meetings available in and around ${city}, with meetings held every day of the week at various times.`
  },
  {
    question: `What types of AA meetings are available in ${city}?`,
    answer: `${city} offers a variety of AA meeting types including Open meetings, Closed meetings, Speaker meetings, Discussion meetings, Big Book study, Step meetings, and specialty meetings for men, women, and young people.`
  },
  {
    question: `Are there AA meetings near ${city} every day?`,
    answer: `Yes, AA meetings are held in ${city} every day of the week, including weekends and holidays. Meetings are available in the morning, afternoon, evening, and night.`
  },
  {
    question: `Are there online AA meetings available in ${city}?`,
    answer: `Yes, there are online AA meetings available to people in ${city}. These virtual meetings allow you to participate from anywhere and are especially helpful for those with mobility issues or scheduling conflicts.`
  },
  {
    question: `How do I find wheelchair accessible AA meetings in ${city}?`,
    answer: `Many AA meetings in ${city} are wheelchair accessible. Look for the wheelchair accessibility badge on meeting listings, or use the filters on this page to show only accessible meetings.`
  },
  {
    question: `What should I expect at my first AA meeting in ${city}?`,
    answer: `Your first AA meeting in ${city} will be welcoming and supportive. You don't have to speak or share—just listening is perfectly fine. Most meetings last about an hour.`
  },
  {
    question: `How often are AA meeting listings updated for ${city}?`,
    answer: `AA meeting listings for ${city} are updated regularly to help ensure accuracy. Meeting information is sourced from local AA intergroups and verified frequently.`
  },
  {
    question: `Can I find AA meetings outside ${city}, ${stateFull}?`,
    answer: `Yes. You can browse nearby cities in ${stateFull} using the Other Locations section on this page to find additional meeting options.`
  }
];
---

<section class="section-card faq-content" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="section-title">Frequently Asked Questions</h2>
  <div class="faq-list">
    {faqs.map((faq) => (
      <details class="faq-item">
        <summary class="faq-question">{faq.question}</summary>
        <p class="faq-answer">{faq.answer}</p>
      </details>
    ))}
  </div>
</section>

<style>
  .faq-content {
    margin-top: 1.5rem;
  }

  .faq-list {
    display: grid;
    gap: 0.75rem;
  }

  .faq-item {
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    background: #fff;
  }

  .faq-question {
    cursor: pointer;
    font-weight: 600;
    color: #2a3a4d;
    line-height: 1.45;
  }

  .faq-answer {
    margin: 0.75rem 0 0;
    color: #4a5a6a;
    line-height: 1.65;
  }

  .faq-item[open] {
    border-color: #2A9D8F;
  }
</style>