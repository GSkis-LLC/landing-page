  <div class="leads-view" id="leads-view-companies">
    <div class="leads-toolbar">
      <button class="leads-btn" id="companies-refresh-btn">Refresh</button>
    </div>
    <div class="leads-status-bar" id="companies-status"></div>
    <div class="company-cards" id="companies-list"></div>
    <div class="leads-pagination" id="companies-pagination" style="display:none;">
      <div class="leads-pagination-info"><span id="companies-page-info"></span></div>
      <div class="leads-pagination-btns">
        <button id="companies-page-prev" disabled>← Prev</button>
        <button id="companies-page-next" disabled>Next →</button>
      </div>
    </div>
  </div>

  <!-- ── Templates View ── -->
  <div class="leads-view" id="leads-view-templates">
    <div class="leads-status-bar" id="templates-status"></div>
    <div class="leads-templates-grid" id="templates-grid"></div>
  </div>

  <!-- ── Audit Log View ── -->
  <div class="leads-view" id="leads-view-audit">
    <div class="leads-toolbar">
      <button class="leads-btn" id="audit-refresh-btn">Refresh</button>
    </div>
    <div class="leads-status-bar" id="audit-status"></div>
    <div class="audit-cards" id="audit-cards"></div>
    <div class="leads-pagination" id="audit-pagination" style="display:none;">
      <div class="leads-pagination-info"><span id="audit-page-info"></span></div>
      <div class="leads-pagination-btns">
        <button id="audit-page-prev" disabled>← Prev</button>
        <button id="audit-page-next" disabled>Next →</button>
      </div>
    </div>
  </div>

  <!-- ── Send Email Modal ── -->
  <div class="leads-modal-backdrop" id="leads-email-modal" style="display:none;">
    <div class="leads-modal leads-modal-wide">
      <div class="leads-modal-header">
        <h3>Send Email</h3>
        <button class="leads-modal-close" id="leads-email-modal-close">&times;</button>
      </div>
      <div class="leads-modal-body">
        <p class="leads-modal-info" id="leads-email-info"></p>

        <label class="leads-label">Template</label>
        <select id="leads-email-template" class="leads-select leads-select-full"></select>

        <div class="leads-email-data-ctx" id="leads-email-data-ctx"></div>

        <label class="leads-label">Preview</label>
        <div class="leads-email-preview" id="leads-email-preview"></div>

        <div class="leads-email-legend">
          <span><span class="dot dot-resolved"></span> Resolved</span>
          <span><span class="dot dot-fallback"></span> Fallback used</span>
          <span><span class="dot dot-missing"></span> Missing &amp; no fallback</span>
        </div>
      </div>
      <div class="leads-modal-footer">
        <button class="leads-btn leads-btn-ghost" id="leads-email-cancel">Cancel</button>
        <button class="leads-btn leads-btn-primary" id="leads-email-send">Send Email</button>
      </div>
    </div>
  </div>

  <!-- ── Contact Edit Modal ── -->
  <div class="leads-modal-backdrop" id="leads-contact-modal" style="display:none;">
    <div class="leads-modal">
      <div class="leads-modal-header">
        <h3 id="contact-modal-title">Edit Contact</h3>
        <button class="leads-modal-close" id="contact-modal-close">&times;</button>
      </div>
      <div class="leads-modal-body">
        <p class="leads-modal-info" id="contact-modal-info"></p>
        <label class="leads-label">Name</label>
        <input type="text" class="leads-input" id="contact-name" placeholder="Jane Doe" />
        <label class="leads-label">Email</label>
        <input type="email" class="leads-input" id="contact-email" placeholder="jane@company.com" />
        <label class="leads-label">Phone</label>
        <input type="tel" class="leads-input" id="contact-phone" placeholder="+1 617-555-1212" />
        <label class="leads-label">Role</label>
        <input type="text" class="leads-input" id="contact-role" placeholder="Owner" />
        <label class="leads-label">Source URL</label>
        <input type="url" class="leads-input" id="contact-source-url" placeholder="https://company.com/contact" />
        <div id="contact-assign-section" style="display:none;">
          <div class="leads-checkbox-row">
            <input type="checkbox" id="contact-assign-leads" />
            <label for="contact-assign-leads">Assign this contact to company leads</label>
          </div>
          <div id="contact-force-section" style="display:none;">
            <div class="leads-checkbox-row">
              <input type="checkbox" id="contact-force-assign" />
              <label for="contact-force-assign">Overwrite existing lead contacts</label>
            </div>
            <p class="leads-checkbox-hint">When unchecked, only fills leads with no contact assigned.</p>
          </div>
        </div>
      </div>
      <div class="leads-modal-footer">
        <button class="leads-btn leads-btn-ghost" id="contact-modal-cancel">Cancel</button>
        <button class="leads-btn leads-btn-primary" id="contact-modal-save">Save Contact</button>
      </div>
    </div>
  </div>

  <!-- ── Company Edit Modal ── -->
  <div class="leads-modal-backdrop" id="leads-company-modal" style="display:none;">
    <div class="leads-modal leads-modal-wide">
      <div class="leads-modal-header">
        <h3 id="company-modal-title">Edit Company</h3>
        <button class="leads-modal-close" id="company-modal-close">&times;</button>
      </div>
      <div class="leads-modal-body">
        <p class="leads-modal-info" id="company-modal-info"></p>
        <div class="leads-input-row">
          <div class="leads-input-group">
            <label class="leads-label">Name</label>
            <input type="text" class="leads-input" id="company-edit-name" placeholder="Company Name" />
          </div>
          <div class="leads-input-group">
            <label class="leads-label">Domain</label>
            <input type="text" class="leads-input" id="company-edit-domain" placeholder="example.com" />
          </div>
        </div>
        <div class="leads-input-row">
          <div class="leads-input-group">
            <label class="leads-label">City</label>
            <input type="text" class="leads-input" id="company-edit-city" placeholder="Boston" />
          </div>
          <div class="leads-input-group">
            <label class="leads-label">State</label>
            <input type="text" class="leads-input" id="company-edit-state" placeholder="MA" />
          </div>
        </div>
        <div class="leads-input-row">
          <div class="leads-input-group">
            <label class="leads-label">Country</label>
            <input type="text" class="leads-input" id="company-edit-country" placeholder="United States" />
          </div>
          <div class="leads-input-group">
            <label class="leads-label">Type</label>
            <select class="leads-input leads-select" id="company-edit-type" style="height:2.35rem;">
              <option value="">Select type…</option>
              <option value="sober_house">Sober House</option>
              <option value="rehab">Rehab</option>
              <option value="blog">Blog</option>
              <option value="municipality">Municipality</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
        <div class="leads-input-row">
          <div class="leads-input-group">
            <label class="leads-label">Relevance Score (0–100)</label>
            <input type="number" class="leads-input" id="company-edit-score" min="0" max="100" placeholder="85" />
          </div>
          <div class="leads-input-group">
            <label class="leads-label">Source URL</label>
            <input type="url" class="leads-input" id="company-edit-source-url" placeholder="https://…" />
          </div>
        </div>
      </div>
      <div class="leads-modal-footer">
        <button class="leads-btn leads-btn-ghost" id="company-modal-cancel">Cancel</button>
        <button class="leads-btn leads-btn-primary" id="company-modal-save">Save Company</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  const LEADS_API = 'https://leads-engine-1fecdf3ac4fa.herokuapp.com';

  // Helper to get token from parent scope
  function getToken() { return window.__parmenterToken; }

  function authHeaders() {
    return { 'Authorization': `Bearer ${getToken()}`, 'Content-Type': 'application/json' };
  }

  // ── State ──
  let leads = [];
  let companies = [];
  let templates = [];
  let auditLogs = [];
  let emailModalLead = null;
  let leadsLoaded = false;

  // Pagination state
  let leadsPagination = { total: 0, limit: 25, offset: 0, pages: 0 };
  let companiesPagination = { total: 0, limit: 25, offset: 0, pages: 0 };
  let auditPagination = { total: 0, limit: 25, offset: 0, pages: 0 };
  let auditLoaded = false;

  // Contact modal state
  let contactModalMode = null; // 'lead' or 'company'
  let contactModalEntityId = null;
  let contactModalEntity = null;

  // ── DOM ──
  const subnavBtns = document.querySelectorAll('.leads-subnav-btn');
  const views = document.querySelectorAll('.leads-view');

  // Sub-nav switching
  subnavBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.leadsView;
      subnavBtns.forEach(b => b.classList.toggle('active', b === btn));
      views.forEach(v => v.classList.toggle('active', v.id === `leads-view-${view}`));
      // Lazy load on first visit
      if (view === 'leads' && !leadsLoaded) fetchLeads();
      if (view === 'companies' && companiesPagination.total === 0 && companies.length === 0) fetchCompanies();
      if (view === 'templates' && templates.length === 0) fetchTemplates();
      if (view === 'audit' && !auditLoaded) fetchAuditLogs();
    });
  });

  // ── Leads ──
  const leadsStatusFilter = document.getElementById('leads-status-filter');
  const leadsRefreshBtn = document.getElementById('leads-refresh-btn');
  const leadsTbody = document.getElementById('leads-tbody');
  const leadsStatus = document.getElementById('leads-status');

  leadsRefreshBtn.addEventListener('click', () => { leadsPagination.offset = 0; fetchLeads(); });
  leadsStatusFilter.addEventListener('change', () => { leadsPagination.offset = 0; fetchLeads(); });

  // Pagination DOM
  const leadsPaginationEl = document.getElementById('leads-pagination');
  const leadsPageInfo = document.getElementById('leads-page-info');
  const leadsPagePrev = document.getElementById('leads-page-prev');
  const leadsPageNext = document.getElementById('leads-page-next');

  leadsPagePrev.addEventListener('click', () => {
    leadsPagination.offset = Math.max(0, leadsPagination.offset - leadsPagination.limit);
    fetchLeads();
  });
  leadsPageNext.addEventListener('click', () => {
    leadsPagination.offset += leadsPagination.limit;
    fetchLeads();
  });

  async function fetchLeads() {
    const status = leadsStatusFilter.value;
    leadsStatus.textContent = 'Loading leads…';
    leadsStatus.classList.remove('error');
    try {
      const params = new URLSearchParams();
      if (status) params.set('status', status);
      params.set('limit', String(leadsPagination.limit));
      params.set('offset', String(leadsPagination.offset));
      const url = `${LEADS_API}/leads?${params.toString()}`;
      const res = await fetch(url, { headers: authHeaders() });
      if (!res.ok) throw new Error((await res.json()).error || `HTTP ${res.status}`);
      const json = await res.json();
      leads = json.data;
      leadsPagination = json.pagination;
      leadsLoaded = true;
      const start = leadsPagination.offset + 1;
      const end = Math.min(leadsPagination.offset + leads.length, leadsPagination.total);
      leadsStatus.textContent = `${leadsPagination.total} lead${leadsPagination.total !== 1 ? 's' : ''}`;
      renderLeads();
      renderLeadsPagination(start, end);
    } catch (e) {
      leadsStatus.textContent = e.message;
      leadsStatus.classList.add('error');
    }
  }

  function renderLeadsPagination(start, end) {
    if (leadsPagination.total <= leadsPagination.limit) {
      leadsPaginationEl.style.display = 'none';
      return;
    }
    leadsPaginationEl.style.display = 'flex';
    const currentPage = Math.floor(leadsPagination.offset / leadsPagination.limit) + 1;
    leadsPageInfo.textContent = `${start}–${end} of ${leadsPagination.total}  ·  Page ${currentPage} of ${leadsPagination.pages}`;
    leadsPagePrev.disabled = leadsPagination.offset <= 0;
    leadsPageNext.disabled = leadsPagination.offset + leadsPagination.limit >= leadsPagination.total;
  }

  function buildContactCell(ct) {
    if (!ct || (!ct.name && !ct.email)) {
      return '<span class="leads-contact-none">No contact</span>';
    }
    const chipLabel = ct.name || ct.email || 'Contact';
    const rows = [];
    if (ct.name) rows.push(`<div class="leads-contact-popover-row"><span class="leads-contact-popover-label">Name</span><span class="leads-contact-popover-value">${esc(ct.name)}</span></div>`);
    if (ct.role) rows.push(`<div class="leads-contact-popover-row"><span class="leads-contact-popover-label">Role</span><span class="leads-contact-popover-value">${esc(ct.role)}</span></div>`);
    if (ct.email) rows.push(`<div class="leads-contact-popover-row"><span class="leads-contact-popover-label">Email</span><span class="leads-contact-popover-value"><a href="mailto:${escAttr(ct.email)}">${esc(ct.email)}</a></span></div>`);
    if (ct.phone) rows.push(`<div class="leads-contact-popover-row"><span class="leads-contact-popover-label">Phone</span><span class="leads-contact-popover-value"><a href="tel:${escAttr(ct.phone)}">${esc(ct.phone)}</a></span></div>`);
    if (ct.source_url) rows.push(`<div class="leads-contact-popover-row"><span class="leads-contact-popover-label">Source</span><span class="leads-contact-popover-value"><a href="${escAttr(ct.source_url)}" target="_blank" rel="noopener">${esc(ct.source_url.replace(/^https?:\/\//, '').slice(0, 35))}${ct.source_url.replace(/^https?:\/\//, '').length > 35 ? '…' : ''}</a></span></div>`);
    return `<div class="leads-contact-chip" data-contact-toggle><span class="leads-contact-chip-name">${esc(chipLabel)}</span><span class="leads-contact-chip-arrow">▼</span></div><div class="leads-contact-popover">${rows.join('')}</div>`;
  }

  function renderLeads() {
    leadsTbody.innerHTML = leads.map(lead => {
      const c = lead.Company || {};
      const ct = lead.Contact || {};
      const companyId = lead.company_id || c.id || '';
      const scoreClass = (c.relevance_score || 0) >= 80 ? 'high' : (c.relevance_score || 0) >= 60 ? 'med' : 'low';
      const contacted = lead.last_contacted_at ? new Date(lead.last_contacted_at).toLocaleDateString() : '—';
      const contactCell = buildContactCell(lead.Contact);
      return `<tr>
        <td><strong>${esc(c.name || '—')}</strong> ${companyId ? `<button class="company-edit-inline" data-edit-company-from-lead="${companyId}" title="Edit company">✎</button>` : ''}</td>
        <td>${c.domain ? `<a href="https://${esc(c.domain)}" target="_blank" rel="noopener" style="color:#5eead4;text-decoration:none;">${esc(c.domain)}</a>` : '—'}</td>
        <td>${esc(c.city || '')}${c.city && c.state ? ', ' : ''}${esc(c.state || '')}</td>
        <td>${esc(c.type || '—')}</td>
        <td><span class="leads-score leads-score-${scoreClass}">${c.relevance_score ?? '—'}</span></td>
        <td class="leads-contact-td">${contactCell}</td>
        <td><span class="leads-badge leads-badge-${lead.status}">${esc(lead.status)}</span></td>
        <td>${contacted}</td>
        <td class="leads-actions">
          <select data-lead-status="${lead.id}">
            <option value="" disabled selected>Set status…</option>
            <option value="viewed">Viewed</option>
            <option value="ignored">Ignored</option>
            <option value="replied">Replied</option>
            <option value="bad_fit">Bad Fit</option>
          </select>
          <button class="leads-btn leads-btn-sm" data-lead-contact="${lead.id}" title="Edit contact">✎</button>
          ${ct.email ? `<button class="leads-btn leads-btn-primary" data-lead-email="${lead.id}">✉ Email</button>` : ''}
        </td>
      </tr>`;
    }).join('');

    // Status change handlers
    leadsTbody.querySelectorAll('[data-lead-status]').forEach(sel => {
      sel.addEventListener('change', async () => {
        const id = sel.dataset.leadStatus;
        const newStatus = sel.value;
        sel.disabled = true;
        try {
          const res = await fetch(`${LEADS_API}/leads/${encodeURIComponent(id)}/status`, {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({ status: newStatus }),
          });
          if (!res.ok) throw new Error((await res.json()).error || 'Failed');
          await fetchLeads();
        } catch (e) {
          alert('Status update failed: ' + e.message);
          sel.value = '';
        } finally {
          sel.disabled = false;
        }
      });
    });

    // Email button handlers
    leadsTbody.querySelectorAll('[data-lead-email]').forEach(btn => {
      btn.addEventListener('click', () => openEmailModal(btn.dataset.leadEmail));
    });

    // Contact edit button handlers
    leadsTbody.querySelectorAll('[data-lead-contact]').forEach(btn => {
      btn.addEventListener('click', () => openContactModal('lead', btn.dataset.leadContact));
    });

    // Company edit button handlers (from leads tab)
    leadsTbody.querySelectorAll('[data-edit-company-from-lead]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        openCompanyModal(btn.dataset.editCompanyFromLead, 'leads');
      });
    });

    // Contact popover toggle handlers
    leadsTbody.querySelectorAll('[data-contact-toggle]').forEach(chip => {
      chip.addEventListener('click', (e) => {
        e.stopPropagation();
        const popover = chip.nextElementSibling;
        const isOpen = popover.classList.contains('open');
        // Close all other open popovers first
        leadsTbody.querySelectorAll('.leads-contact-popover.open').forEach(p => {
          p.classList.remove('open');
          p.previousElementSibling.classList.remove('open');
        });
        if (!isOpen) {
          popover.classList.add('open');
          chip.classList.add('open');
        }
      });
    });
  }

  // Close contact popovers when clicking outside
  document.addEventListener('click', () => {
    document.querySelectorAll('.leads-contact-popover.open').forEach(p => {
      p.classList.remove('open');
      p.previousElementSibling.classList.remove('open');
    });
  });

  // ── Email Modal ──
  const emailModal = document.getElementById('leads-email-modal');
  const emailInfo = document.getElementById('leads-email-info');
  const emailTemplateSelect = document.getElementById('leads-email-template');
  const emailPreview = document.getElementById('leads-email-preview');
  const emailSendBtn = document.getElementById('leads-email-send');
  const emailCancelBtn = document.getElementById('leads-email-cancel');
  const emailCloseBtn = document.getElementById('leads-email-modal-close');

  const emailDataCtx = document.getElementById('leads-email-data-ctx');

  // Build the variable lookup map from a lead's Company + Contact
  function buildVarMap(lead) {
    const c = lead.Company || {};
    const ct = lead.Contact || {};
    return {
      company_name:   c.name || '',
      company_domain: c.domain || '',
      city:           c.city || '',
      state:          c.state || '',
      country:        c.country || '',
      company_type:   c.type || '',
      relevance_score: c.relevance_score != null ? String(c.relevance_score) : '',
      contact_name:   ct.name || '',
      contact_email:  ct.email || '',
      contact_phone:  ct.phone || '',
      contact_role:   ct.role || '',
    };
  }

  async function openEmailModal(leadId) {
    emailModalLead = leads.find(l => l.id === leadId);
    if (!emailModalLead) return;

    const ct = emailModalLead.Contact || {};
    const c = emailModalLead.Company || {};
    emailInfo.textContent = `To: ${ct.email || '—'} (${c.name || 'Unknown'})`;

    // Ensure templates loaded
    if (templates.length === 0) await fetchTemplates();
    emailTemplateSelect.innerHTML = templates.map(t =>
      `<option value="${t.id}">${esc(t.name)}</option>`
    ).join('');

    renderDataContext();
    updateEmailPreview();
    emailModal.style.display = 'flex';
  }

  // Render the data context panel so the user can see what values are available
  function renderDataContext() {
    if (!emailModalLead) { emailDataCtx.innerHTML = ''; return; }
    const varMap = buildVarMap(emailModalLead);
    const companyVars = ['company_name','company_domain','city','state','country','company_type','relevance_score'];
    const contactVars = ['contact_name','contact_email','contact_phone','contact_role'];

    function renderRows(keys) {
      return keys.map(k => {
        const val = varMap[k];
        const valHtml = val
          ? `<span class="leads-email-data-val">${esc(val)}</span>`
          : `<span class="leads-email-data-val empty">empty</span>`;
        return `<div class="leads-email-data-row"><span class="leads-email-data-key">{{${k}}}</span>${valHtml}</div>`;
      }).join('');
    }

    emailDataCtx.innerHTML =
      `<div class="leads-email-data-ctx-title">Company data</div>` +
      renderRows(companyVars) +
      `<div class="leads-email-data-ctx-title" style="margin-top:0.35rem;">Contact data</div>` +
      renderRows(contactVars);
  }

  function updateEmailPreview() {
    const tpl = templates.find(t => t.id === emailTemplateSelect.value);
    if (!tpl || !emailModalLead) { emailPreview.innerHTML = ''; return; }
    const varMap = buildVarMap(emailModalLead);
    const subjectHtml = renderTplHtml(tpl.subject, varMap);
    const bodyHtml = renderTplHtml(tpl.body, varMap);
    emailPreview.innerHTML =
      `<div class="leads-email-preview-subject">Subject: ${subjectHtml}</div>${bodyHtml}`;
  }

  // Replace {{var}} and {{var|fallback}} with color-coded HTML spans
  function renderTplHtml(str, varMap) {
    return esc(str || '').replace(/\{\{(\w+?)(?:\|([^}]*))?\}\}/g, (match, key, fallback) => {
      const val = varMap[key];
      if (val) {
        return `<span class="tpl-resolved" title="{{${key}}} → ${esc(val)}">${esc(val)}</span>`;
      }
      if (fallback !== undefined && fallback !== '') {
        return `<span class="tpl-fallback" title="{{${key}}} was empty — using fallback">${esc(fallback)}</span>`;
      }
      return `<span class="tpl-missing" title="{{${key}}} is empty and has no fallback">⚠ ${esc(key)}</span>`;
    });
  }

  emailTemplateSelect.addEventListener('change', updateEmailPreview);

  emailCancelBtn.addEventListener('click', () => { emailModal.style.display = 'none'; });
  emailCloseBtn.addEventListener('click', () => { emailModal.style.display = 'none'; });
  emailModal.addEventListener('click', (e) => { if (e.target === emailModal) emailModal.style.display = 'none'; });

  emailSendBtn.addEventListener('click', async () => {
    if (!emailModalLead) return;
    const templateId = emailTemplateSelect.value;
    if (!templateId) { alert('Select a template'); return; }

    emailSendBtn.disabled = true;
    emailSendBtn.textContent = 'Sending…';
    try {
      const res = await fetch(`${LEADS_API}/leads/${encodeURIComponent(emailModalLead.id)}/send-email`, {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({ templateId }),
      });
      if (!res.ok) throw new Error((await res.json()).error || 'Send failed');
      emailModal.style.display = 'none';
      await fetchLeads();
    } catch (e) {
      alert('Send failed: ' + e.message);
    } finally {
      emailSendBtn.disabled = false;
      emailSendBtn.textContent = 'Send Email';
    }
  });

  // ── Companies ──
  const companiesStatus = document.getElementById('companies-status');
  document.getElementById('companies-refresh-btn').addEventListener('click', () => { companiesPagination.offset = 0; fetchCompanies(); });

  // Companies pagination DOM
  const companiesPaginationEl = document.getElementById('companies-pagination');
  const companiesPageInfo = document.getElementById('companies-page-info');
  const companiesPagePrev = document.getElementById('companies-page-prev');
  const companiesPageNext = document.getElementById('companies-page-next');

  companiesPagePrev.addEventListener('click', () => {
    companiesPagination.offset = Math.max(0, companiesPagination.offset - companiesPagination.limit);
    fetchCompanies();
  });
  companiesPageNext.addEventListener('click', () => {
    companiesPagination.offset += companiesPagination.limit;
    fetchCompanies();
  });

  async function fetchCompanies() {
    companiesStatus.textContent = 'Loading companies…';
    companiesStatus.classList.remove('error');
    try {
      const params = new URLSearchParams();
      params.set('limit', String(companiesPagination.limit));
      params.set('offset', String(companiesPagination.offset));
      const res = await fetch(`${LEADS_API}/companies?${params.toString()}`, { headers: authHeaders() });
      if (!res.ok) throw new Error((await res.json()).error || `HTTP ${res.status}`);
      const json = await res.json();
      companies = json.data;
      companiesPagination = json.pagination;
      const start = companiesPagination.offset + 1;
      const end = Math.min(companiesPagination.offset + companies.length, companiesPagination.total);
      companiesStatus.textContent = `${companiesPagination.total} compan${companiesPagination.total !== 1 ? 'ies' : 'y'}`;
      renderCompanies();
      renderCompaniesPagination(start, end);
    } catch (e) {
      companiesStatus.textContent = e.message;
      companiesStatus.classList.add('error');
    }
  }

  function renderCompaniesPagination(start, end) {
    if (companiesPagination.total <= companiesPagination.limit) {
      companiesPaginationEl.style.display = 'none';
      return;
    }
    companiesPaginationEl.style.display = 'flex';
    const currentPage = Math.floor(companiesPagination.offset / companiesPagination.limit) + 1;
    companiesPageInfo.textContent = `${start}–${end} of ${companiesPagination.total}  ·  Page ${currentPage} of ${companiesPagination.pages}`;
    companiesPagePrev.disabled = companiesPagination.offset <= 0;
    companiesPageNext.disabled = companiesPagination.offset + companiesPagination.limit >= companiesPagination.total;
  }

  function renderCompanies() {
    const companiesList = document.getElementById('companies-list');
    companiesList.innerHTML = companies.map(c => {
      const scoreClass = (c.relevance_score || 0) >= 80 ? 'high' : (c.relevance_score || 0) >= 60 ? 'med' : 'low';
      const contacts = c.Contacts || [];
      const location = [c.city, c.state].filter(Boolean).join(', ');

      const contactRows = contacts.length ? contacts.map(ct => {
        const nameStr = ct.name ? esc(ct.name) : '<span style="color:#64748b;font-style:italic;">Unnamed</span>';
        const roleStr = ct.role ? `<span class="company-contact-primary-role">${esc(ct.role)}</span>` : '';
        const fields = [];
        if (ct.email) fields.push(`<span class="company-contact-field"><span class="company-contact-field-icon">✉</span><a href="mailto:${escAttr(ct.email)}">${esc(ct.email)}</a></span>`);
        if (ct.phone) fields.push(`<span class="company-contact-field"><span class="company-contact-field-icon">☎</span><a href="tel:${escAttr(ct.phone)}">${esc(ct.phone)}</a></span>`);
        if (ct.source_url) fields.push(`<span class="company-contact-field"><span class="company-contact-field-icon">🔗</span><a href="${escAttr(ct.source_url)}" target="_blank" rel="noopener">${esc(ct.source_url.replace(/^https?:\/\//, '').slice(0, 30))}${ct.source_url.replace(/^https?:\/\//, '').length > 30 ? '…' : ''}</a></span>`);
        return `<div class="company-contact-row">
          <div class="company-contact-primary">
            <span class="company-contact-primary-name">${nameStr}</span>
            ${roleStr}
          </div>
          <div class="company-contact-fields">${fields.join('')}</div>
          <div class="company-contact-actions">
            <button class="leads-btn leads-btn-sm" data-company-id="${c.id}" data-contact-id="${ct.id}" title="Edit contact">✎</button>
          </div>
        </div>`;
      }).join('') : '<div class="company-no-contacts">No contacts found for this company</div>';

      return `<div class="company-card">
        <div class="company-card-header" data-company-toggle="${c.id}">
          <span class="company-card-expand">▶</span>
          <span class="company-card-name">${esc(c.name || '—')}</span>
          ${c.domain ? `<a href="https://${esc(c.domain)}" target="_blank" rel="noopener" class="company-card-domain" onclick="event.stopPropagation();">${esc(c.domain)}</a>` : ''}
          <div class="company-card-meta">
            ${location ? `<span class="company-card-meta-item">📍 ${esc(location)}</span>` : ''}
            <span class="company-card-meta-item">${esc(c.type || '—')}</span>
            <span class="leads-score leads-score-${scoreClass}" style="font-size:0.7rem;">${c.relevance_score ?? '—'}</span>
            <span class="company-card-meta-item">${contacts.length} contact${contacts.length !== 1 ? 's' : ''}</span>
            ${c.source_url ? `<span class="company-card-source"><a href="${escAttr(c.source_url)}" target="_blank" rel="noopener" onclick="event.stopPropagation();">Source</a></span>` : ''}
            <button class="company-edit-inline" data-edit-company="${c.id}" onclick="event.stopPropagation();" title="Edit company">✎</button>
          </div>
        </div>
        <div class="company-card-body">
          <div class="company-contacts-header">
            <span class="company-contacts-title">Contacts</span>
            <button class="leads-btn leads-btn-sm leads-btn-primary" data-add-contact="${c.id}">+ Add Contact</button>
          </div>
          ${contactRows}
        </div>
      </div>`;
    }).join('');

    // Toggle expand/collapse
    companiesList.querySelectorAll('[data-company-toggle]').forEach(header => {
      header.addEventListener('click', () => {
        header.closest('.company-card').classList.toggle('open');
      });
    });

    // Edit contact buttons (per-contact)
    companiesList.querySelectorAll('[data-contact-id]').forEach(btn => {
      btn.addEventListener('click', () => {
        openContactModal('company', btn.dataset.companyId, btn.dataset.contactId);
      });
    });

    // Add contact buttons (company-level, no contactId)
    companiesList.querySelectorAll('[data-add-contact]').forEach(btn => {
      btn.addEventListener('click', () => {
        openContactModal('company', btn.dataset.addContact, null);
      });
    });

    // Company edit buttons
    companiesList.querySelectorAll('[data-edit-company]').forEach(btn => {
      btn.addEventListener('click', () => {
        openCompanyModal(btn.dataset.editCompany, 'companies');
      });
    });
  }

  // ── Templates ──
  const templatesGrid = document.getElementById('templates-grid');
  const templatesStatus = document.getElementById('templates-status');

  async function fetchTemplates() {
    templatesStatus.textContent = 'Loading templates…';
    templatesStatus.classList.remove('error');
    try {
      const res = await fetch(`${LEADS_API}/templates`, { headers: authHeaders() });
      if (!res.ok) throw new Error((await res.json()).error || `HTTP ${res.status}`);
      templates = await res.json();
      templatesStatus.textContent = `${templates.length} template${templates.length !== 1 ? 's' : ''}`;
      renderTemplates();
    } catch (e) {
      templatesStatus.textContent = e.message;
      templatesStatus.classList.add('error');
    }
  }

  function renderTemplates() {
    templatesGrid.innerHTML = templates.map(t => `
      <div class="leads-template-card" data-tpl-id="${t.id}">
        <h4>${esc(t.name)}</h4>
        <div class="template-type">${esc(t.type)}</div>
        <label>Subject</label>
        <input type="text" class="tpl-subject" value="${escAttr(t.subject)}" />
        <label>Body</label>
        <textarea class="tpl-body">${esc(t.body)}</textarea>
        <div class="template-actions">
          <button class="leads-btn leads-btn-sm leads-btn-primary tpl-save-btn">Save</button>
        </div>
      </div>
    `).join('');

    templatesGrid.querySelectorAll('.tpl-save-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const card = btn.closest('.leads-template-card');
        const id = card.dataset.tplId;
        const subject = card.querySelector('.tpl-subject').value;
        const body = card.querySelector('.tpl-body').value;
        btn.disabled = true;
        btn.textContent = 'Saving…';
        try {
          const res = await fetch(`${LEADS_API}/templates/${encodeURIComponent(id)}`, {
            method: 'PUT',
            headers: authHeaders(),
            body: JSON.stringify({ subject, body }),
          });
          if (!res.ok) throw new Error((await res.json()).error || 'Save failed');
          const updated = await res.json();
          const idx = templates.findIndex(t => t.id === id);
          if (idx !== -1) templates[idx] = updated;
          btn.textContent = 'Saved!';
          setTimeout(() => { btn.textContent = 'Save'; }, 1500);
        } catch (e) {
          alert('Save failed: ' + e.message);
          btn.textContent = 'Save';
        } finally {
          btn.disabled = false;
        }
      });
    });
  }

  // ── Audit Logs ──
  const auditCardsEl = document.getElementById('audit-cards');
  const auditStatus = document.getElementById('audit-status');
  const auditPaginationEl = document.getElementById('audit-pagination');
  const auditPageInfo = document.getElementById('audit-page-info');
  const auditPagePrev = document.getElementById('audit-page-prev');
  const auditPageNext = document.getElementById('audit-page-next');

  document.getElementById('audit-refresh-btn').addEventListener('click', () => { auditPagination.offset = 0; fetchAuditLogs(); });
  auditPagePrev.addEventListener('click', () => {
    auditPagination.offset = Math.max(0, auditPagination.offset - auditPagination.limit);
    fetchAuditLogs();
  });
  auditPageNext.addEventListener('click', () => {
    auditPagination.offset += auditPagination.limit;
    fetchAuditLogs();
  });

  async function fetchAuditLogs() {
    auditStatus.textContent = 'Loading audit logs…';
    auditStatus.classList.remove('error');
    try {
      const params = new URLSearchParams();
      params.set('limit', String(auditPagination.limit));
      params.set('offset', String(auditPagination.offset));
      const res = await fetch(`${LEADS_API}/audit-logs?${params.toString()}`, { headers: authHeaders() });
      if (!res.ok) throw new Error((await res.json()).error || `HTTP ${res.status}`);
      const json = await res.json();
      auditLogs = json.data;
      auditPagination = json.pagination;
      auditLoaded = true;
      const start = auditPagination.offset + 1;
      const end = Math.min(auditPagination.offset + auditLogs.length, auditPagination.total);
      auditStatus.textContent = `${auditPagination.total} entr${auditPagination.total !== 1 ? 'ies' : 'y'}`;
      renderAuditLogs();
      renderAuditPagination(start, end);
    } catch (e) {
      auditStatus.textContent = e.message;
      auditStatus.classList.add('error');
    }
  }

  function renderAuditPagination(start, end) {
    if (auditPagination.total <= auditPagination.limit) {
      auditPaginationEl.style.display = 'none';
      return;
    }
    auditPaginationEl.style.display = 'flex';
    const currentPage = Math.floor(auditPagination.offset / auditPagination.limit) + 1;
    auditPageInfo.textContent = `${start}–${end} of ${auditPagination.total}  ·  Page ${currentPage} of ${auditPagination.pages}`;
    auditPagePrev.disabled = auditPagination.offset <= 0;
    auditPageNext.disabled = auditPagination.offset + auditPagination.limit >= auditPagination.total;
  }

  function formatAuditAction(action) {
    const labels = { send_email: 'Email Sent', update_status: 'Status Changed', update_contact: 'Contact Updated', update_company: 'Company Updated' };
    return labels[action] || action;
  }

  function buildAuditContext(log) {
    const lead = log.Lead;
    if (!lead) return '<div class="audit-ctx-block"><span class="audit-ctx-sub" style="font-style:italic;">Lead deleted or unavailable</span></div>';

    const blocks = [];

    // Company context
    const co = lead.Company;
    if (co) {
      let coHtml = `<div class="audit-ctx-value">${esc(co.name || '—')}</div>`;
      if (co.domain) coHtml += `<div class="audit-ctx-sub"><a href="https://${escAttr(co.domain)}" target="_blank" rel="noopener">${esc(co.domain)}</a></div>`;
      if (co.location) coHtml += `<div class="audit-ctx-sub">${esc(co.location)}</div>`;
      blocks.push(`<div class="audit-ctx-block"><div class="audit-ctx-label">Company</div>${coHtml}</div>`);
    }

    // Contact context
    const ct = lead.Contact;
    if (ct && (ct.name || ct.email)) {
      let ctHtml = '';
      if (ct.name) ctHtml += `<div class="audit-ctx-value">${esc(ct.name)}${ct.role ? ` <span class="audit-ctx-sub">· ${esc(ct.role)}</span>` : ''}</div>`;
      if (ct.email) ctHtml += `<div class="audit-ctx-sub"><a href="mailto:${escAttr(ct.email)}">${esc(ct.email)}</a></div>`;
      if (ct.phone) ctHtml += `<div class="audit-ctx-sub">${esc(ct.phone)}</div>`;
      blocks.push(`<div class="audit-ctx-block"><div class="audit-ctx-label">Contact</div>${ctHtml}</div>`);
    }

    // Lead status + score
    const statusCls = lead.status ? `leads-badge-${lead.status}` : 'leads-badge-new';
    blocks.push(`<div class="audit-ctx-block"><div class="audit-ctx-label">Lead</div><div class="audit-ctx-value"><span class="leads-badge ${statusCls}">${esc(lead.status || 'new')}</span></div>${lead.score != null ? `<div class="audit-ctx-sub">Score: ${esc(String(lead.score))}</div>` : ''}</div>`);

    return blocks.join('');
  }

  function buildAuditMeta(log) {
    const meta = log.metadata;
    if (!meta || Object.keys(meta).length === 0) return '';

    const rows = [];

    if (log.action === 'send_email') {
      if (meta.template_name) rows.push(`<div class="audit-meta-row"><span class="audit-meta-key">Template</span><span class="audit-meta-val">${esc(meta.template_name)}</span></div>`);
      if (meta.to) rows.push(`<div class="audit-meta-row"><span class="audit-meta-key">To</span><span class="audit-meta-val">${esc(meta.to)}</span></div>`);
      if (meta.subject) rows.push(`<div class="audit-meta-row"><span class="audit-meta-key">Subject</span><span class="audit-meta-val">${esc(meta.subject)}</span></div>`);
    } else if (log.action === 'update_status') {
      if (meta.from && meta.to) {
        rows.push(`<div class="audit-meta-row"><span class="audit-meta-key">Changed</span><span class="audit-meta-val"><span class="leads-badge leads-badge-${meta.from}">${esc(meta.from)}</span> <span class="audit-meta-arrow">→</span> <span class="leads-badge leads-badge-${meta.to}">${esc(meta.to)}</span></span></div>`);
      }
    } else if (log.action === 'update_contact') {
      const fields = meta.fields_updated || meta.updated_fields;
      if (Array.isArray(fields) && fields.length) {
        rows.push(`<div class="audit-meta-row"><span class="audit-meta-key">Fields</span><span class="audit-meta-val">${fields.map(f => esc(f)).join(', ')}</span></div>`);
      }
    } else if (log.action === 'update_company') {
      const fields = meta.updated_fields;
      if (Array.isArray(fields) && fields.length) {
        rows.push(`<div class="audit-meta-row"><span class="audit-meta-key">Fields</span><span class="audit-meta-val">${fields.map(f => esc(f)).join(', ')}</span></div>`);
      }
      const changes = meta.changes;
      if (changes && typeof changes === 'object') {
        Object.entries(changes).forEach(([k, v]) => {
          rows.push(`<div class="audit-meta-row"><span class="audit-meta-key">${esc(k)}</span><span class="audit-meta-val">${esc(String(v))}</span></div>`);
        });
      }
    }

    // Fallback: show any remaining keys not already rendered
    const shown = new Set(['template_name', 'to', 'subject', 'from', 'fields_updated', 'updated_fields', 'changes']);
    Object.entries(meta).forEach(([k, v]) => {
      if (!shown.has(k) && v != null) {
        rows.push(`<div class="audit-meta-row"><span class="audit-meta-key">${esc(k)}</span><span class="audit-meta-val">${esc(typeof v === 'object' ? JSON.stringify(v) : String(v))}</span></div>`);
      }
    });

    if (rows.length === 0) return '';
    return `<div class="audit-card-meta">${rows.join('')}</div>`;
  }

  function renderAuditLogs() {
    if (auditLogs.length === 0) {
      auditCardsEl.innerHTML = '<div class="audit-empty">No audit log entries found.</div>';
      return;
    }
    auditCardsEl.innerHTML = auditLogs.map(log => {
      const d = log.createdAt ? new Date(log.createdAt) : null;
      const time = d && !isNaN(d.getTime()) ? d.toLocaleString() : '—';
      const actionCls = `audit-action-${log.action || 'send_email'}`;
      const userId = log.user_id != null ? String(log.user_id) : '—';

      return `<div class="audit-card">
        <div class="audit-card-top">
          <span class="audit-card-time">${esc(time)}</span>
          <span class="audit-card-action ${actionCls}">${esc(formatAuditAction(log.action))}</span>
          <span class="audit-card-user">User ${esc(userId)}</span>
        </div>
        <div class="audit-card-context">${buildAuditContext(log)}</div>
        ${buildAuditMeta(log)}
      </div>`;
    }).join('');
  }

  // ── Contact Edit Modal ──
  const contactModal = document.getElementById('leads-contact-modal');
  const contactModalTitle = document.getElementById('contact-modal-title');
  const contactModalInfo = document.getElementById('contact-modal-info');
  const contactName = document.getElementById('contact-name');
  const contactEmail = document.getElementById('contact-email');
  const contactPhone = document.getElementById('contact-phone');
  const contactRole = document.getElementById('contact-role');
  const contactSourceUrl = document.getElementById('contact-source-url');
  const contactAssignSection = document.getElementById('contact-assign-section');
  const contactAssignLeads = document.getElementById('contact-assign-leads');
  const contactForceSection = document.getElementById('contact-force-section');
  const contactForceAssign = document.getElementById('contact-force-assign');
  const contactSaveBtn = document.getElementById('contact-modal-save');
  const contactCancelBtn = document.getElementById('contact-modal-cancel');
  const contactCloseBtn = document.getElementById('contact-modal-close');

  let contactModalContactId = null; // specific contact being edited

  function openContactModal(mode, entityId, contactId) {
    contactModalMode = mode;
    contactModalEntityId = entityId;
    contactModalContactId = contactId || null;

    // Clear fields
    contactName.value = '';
    contactEmail.value = '';
    contactPhone.value = '';
    contactRole.value = '';
    contactSourceUrl.value = '';
    contactAssignLeads.checked = false;
    contactForceAssign.checked = false;

    if (mode === 'lead') {
      const lead = leads.find(l => l.id === entityId);
      contactModalEntity = lead;
      const c = lead?.Company || {};
      const ct = lead?.Contact || {};
      contactModalTitle.textContent = 'Edit Lead Contact';
      contactModalInfo.textContent = `Company: ${c.name || 'Unknown'}`;
      contactName.value = ct.name || '';
      contactEmail.value = ct.email || '';
      contactPhone.value = ct.phone || '';
      contactRole.value = ct.role || '';
      contactSourceUrl.value = ct.source_url || '';
      contactAssignSection.style.display = 'none';
    } else {
      const company = companies.find(c => c.id === entityId);
      contactModalEntity = company;
      let ct = {};
      if (contactId && company?.Contacts) {
        ct = company.Contacts.find(c => c.id === contactId) || {};
        contactModalTitle.textContent = 'Edit Contact';
      } else {
        contactModalTitle.textContent = 'Add New Contact';
      }
      contactModalInfo.textContent = `Company: ${company?.name || 'Unknown'}`;
      contactName.value = ct.name || '';
      contactEmail.value = ct.email || '';
      contactPhone.value = ct.phone || '';
      contactRole.value = ct.role || '';
      contactSourceUrl.value = ct.source_url || '';
      contactAssignSection.style.display = 'block';
    }
    contactForceSection.style.display = contactAssignLeads.checked ? 'block' : 'none';
    contactModal.style.display = 'flex';
  }

  contactAssignLeads.addEventListener('change', () => {
    contactForceSection.style.display = contactAssignLeads.checked ? 'block' : 'none';
    if (!contactAssignLeads.checked) contactForceAssign.checked = false;
  });

  function closeContactModal() { contactModal.style.display = 'none'; }
  contactCancelBtn.addEventListener('click', closeContactModal);
  contactCloseBtn.addEventListener('click', closeContactModal);
  contactModal.addEventListener('click', (e) => { if (e.target === contactModal) closeContactModal(); });

  contactSaveBtn.addEventListener('click', async () => {
    if (!contactModalMode || !contactModalEntityId) return;

    const body = {};
    const name = contactName.value.trim();
    const email = contactEmail.value.trim();
    const phone = contactPhone.value.trim();
    const role = contactRole.value.trim();
    const sourceUrl = contactSourceUrl.value.trim();
    if (name) body.name = name;
    if (email) body.email = email;
    if (phone) body.phone = phone;
    if (role) body.role = role;
    if (sourceUrl) body.source_url = sourceUrl;

    if (contactModalMode === 'company') {
      body.assignToLeads = contactAssignLeads.checked;
      body.forceAssign = contactForceAssign.checked;
      if (contactModalContactId) body.contactId = contactModalContactId;
    }

    contactSaveBtn.disabled = true;
    contactSaveBtn.textContent = 'Saving…';
    try {
      const endpoint = contactModalMode === 'lead'
        ? `${LEADS_API}/leads/${encodeURIComponent(contactModalEntityId)}/contact`
        : `${LEADS_API}/companies/${encodeURIComponent(contactModalEntityId)}/contact`;
      const res = await fetch(endpoint, {
        method: 'PUT',
        headers: authHeaders(),
        body: JSON.stringify(body),
      });
      if (!res.ok) throw new Error((await res.json()).error || 'Save failed');
      closeContactModal();
      if (contactModalMode === 'lead') {
        await fetchLeads();
      } else {
        await fetchCompanies();
      }
    } catch (e) {
      alert('Contact save failed: ' + e.message);
    } finally {
      contactSaveBtn.disabled = false;
      contactSaveBtn.textContent = 'Save Contact';
    }
  });

  // ── Company Edit Modal ──
  const companyModal = document.getElementById('leads-company-modal');
  const companyModalTitle = document.getElementById('company-modal-title');
  const companyModalInfo = document.getElementById('company-modal-info');
  const companyEditName = document.getElementById('company-edit-name');
  const companyEditDomain = document.getElementById('company-edit-domain');
  const companyEditCity = document.getElementById('company-edit-city');
  const companyEditState = document.getElementById('company-edit-state');
  const companyEditCountry = document.getElementById('company-edit-country');
  const companyEditType = document.getElementById('company-edit-type');
  const companyEditScore = document.getElementById('company-edit-score');
  const companyEditSourceUrl = document.getElementById('company-edit-source-url');
  const companyModalSaveBtn = document.getElementById('company-modal-save');
  const companyModalCancelBtn = document.getElementById('company-modal-cancel');
  const companyModalCloseBtn = document.getElementById('company-modal-close');

  let companyModalCompanyId = null;
  let companyModalSource = null; // 'leads' or 'companies'

  function openCompanyModal(companyId, source) {
    companyModalCompanyId = companyId;
    companyModalSource = source;

    // Try to find the company from companies array first, then from leads
    let company = companies.find(c => c.id === companyId);
    if (!company) {
      const lead = leads.find(l => (l.company_id === companyId) || (l.Company && l.Company.id === companyId));
      company = lead?.Company || {};
    }

    companyModalTitle.textContent = 'Edit Company';
    companyModalInfo.textContent = company.name ? `Editing: ${company.name}` : 'Edit company details';
    companyEditName.value = company.name || '';
    companyEditDomain.value = company.domain || '';
    companyEditCity.value = company.city || '';
    companyEditState.value = company.state || '';
    companyEditCountry.value = company.country || '';
    companyEditType.value = company.type || '';
    companyEditScore.value = company.relevance_score != null ? String(company.relevance_score) : '';
    companyEditSourceUrl.value = company.source_url || '';

    companyModal.style.display = 'flex';
  }

  function closeCompanyModal() { companyModal.style.display = 'none'; }
  companyModalCancelBtn.addEventListener('click', closeCompanyModal);
  companyModalCloseBtn.addEventListener('click', closeCompanyModal);
  companyModal.addEventListener('click', (e) => { if (e.target === companyModal) closeCompanyModal(); });

  companyModalSaveBtn.addEventListener('click', async () => {
    if (!companyModalCompanyId) return;

    const body = {};
    const name = companyEditName.value.trim();
    const domain = companyEditDomain.value.trim();
    const city = companyEditCity.value.trim();
    const state = companyEditState.value.trim();
    const country = companyEditCountry.value.trim();
    const type = companyEditType.value;
    const scoreVal = companyEditScore.value.trim();
    const sourceUrl = companyEditSourceUrl.value.trim();

    if (name) body.name = name;
    if (domain) body.domain = domain;
    if (city) body.city = city;
    if (state) body.state = state;
    if (country) body.country = country;
    if (type) body.type = type;
    if (scoreVal !== '') body.relevance_score = parseInt(scoreVal, 10);
    if (sourceUrl) body.source_url = sourceUrl;

    if (Object.keys(body).length === 0) {
      alert('No fields to update.');
      return;
    }

    companyModalSaveBtn.disabled = true;
    companyModalSaveBtn.textContent = 'Saving…';
    try {
      const res = await fetch(`${LEADS_API}/companies/${encodeURIComponent(companyModalCompanyId)}`, {
        method: 'PUT',
        headers: authHeaders(),
        body: JSON.stringify(body),
      });
      if (!res.ok) throw new Error((await res.json()).error || 'Save failed');
      closeCompanyModal();
      // Refresh whichever view the user came from (and both if companies are loaded)
      if (companyModalSource === 'leads' || leadsLoaded) await fetchLeads();
      if (companyModalSource === 'companies' || companies.length > 0) await fetchCompanies();
    } catch (e) {
      alert('Company update failed: ' + e.message);
    } finally {
      companyModalSaveBtn.disabled = false;
      companyModalSaveBtn.textContent = 'Save Company';
    }
  });

  // ── Helpers ──
  function esc(s) {
    const d = document.createElement('div');
    d.textContent = String(s ?? '');
    return d.innerHTML;
  }
  function escAttr(s) {
    return esc(s).replace(/"/g, '&quot;');
  }

  // ── Public initializer (called when tab is activated) ──
  window.__leadsEngineInit = function() {
    if (!leadsLoaded && getToken()) fetchLeads();
  };
})();
</script>
